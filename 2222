                      f"Máxima diferencia {peor:.3f} (empresa: {worst}). "
                      f"Archivo: {os.path.basename(xls[-1])}.")
            wbx.close()
        else:
            check("Reconciliación con Excel de activos", True,
                  "No se encontró el Excel 'Riesgos Climáticos'; se omite.")
    except Exception as e_rec:
