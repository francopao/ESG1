def cargar_modulo(path):
    spec = importlib.util.spec_from_file_location("dpr_audit", path)
    mod  = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod


def instrumentar(mod):
    """Cada wrapper llama al original y devuelve su resultado sin modificarlo."""

    def wrap(nombre, recorder):
        orig = getattr(mod, nombre, None)
        if orig is None:
            return
        def envuelto(*a, **k):
            res = orig(*a, **k)
            try:
                recorder(a, k, res)
            except Exception as e:
                REC["errores"].append(f"recorder {nombre}: {e}")
            return res
        setattr(mod, nombre, envuelto)

    # --- archivos resueltos ---
    def rec_find_file(a, k, res):
        desc = a[2] if len(a) >= 3 else k.get("descripcion", "?")
        REC["files"].append((str(desc), str(res)))
    wrap("find_file", rec_find_file)

    # --- ventana temporal ---
    def rec_meses(a, k, res):
        if REC["ventana_meses"] is None:
            REC["ventana_meses"] = list(res)
    wrap("_meses_semestre_anterior", rec_meses)

    def rec_cols(a, k, res):
        try:
            cols, etq, faltan, fb = res
            REC["ventana_cols"].append((str(etq), len(cols), list(faltan or []), bool(fb)))
        except Exception:
            pass
    wrap("_cols_en_ventana", rec_cols)

    # --- build_model: corazón del reparto producción -> AUM por distrito ---
    def rec_build(a, k, res):
        sector = (a[5] if len(a) >= 6 else k.get("sector", "?"))
        exp    = (a[1] if len(a) >= 2 else k.get("exp", {})) or {}
        try:
            districts, df_assign, um, detalle, no_map, dfm = res
        except Exception:
            return
        REC["build_model"].append({
            "sector":    str(sector),
            "exp":       dict(exp),
            "df_assign": df_assign.copy() if df_assign is not None else None,
            "um":        dict(um)      if isinstance(um,      dict) else {},
            "detalle":   dict(detalle) if isinstance(detalle, dict) else {},
            "n_no_map":  0 if no_map is None else len(no_map),
        })
    wrap("build_model", rec_build)

    # --- exposición por sector ---
    def rec_exp(a, k, res):
        etq = (a[4] if len(a) >= 5 else k.get("etiqueta", "?"))
        REC["exp_sector"].append((str(etq), dict(res or {})))
    wrap("load_exposicion_sector", rec_exp)

    # --- resumen financiero ---
    def rec_fin(a, k, res):
        try:
            df, _ = res
            REC["financiero_df"] = df.copy()
        except Exception:
            pass
    wrap("load_financiero", rec_fin)

    # --- FEN_Apoyo ---
    def rec_fenap(a, k, res):
        REC["fen_apoyo"] = res
    wrap("load_fen_apoyo", rec_fenap)

    def rec_fentab(a, k, res):
        REC["fen_tabla"] = res
    wrap("build_fen_table_data", rec_fentab)

    # --- clase RV/RF + AUM de cartera ---
    def rec_clase(a, k, res):
        REC["exp_clase"] = res
    wrap("load_exposicion_clase", rec_clase)

    # --- districts finales ---
    def rec_merge(a, k, res):
        REC["districts"] = res
    wrap("merge_sectores", rec_merge)

    # --- argumentos de los dos dashboards de interés ---
    def rec_fen(a, k, res):
        REC["dash_fen"] = {"args": a, "kwargs": k}
    wrap("_generar_fen_chart", rec_fen)

    def rec_act(a, k, res):
        REC["dash_act"] = {"args": a, "kwargs": k}
    wrap("generar_dashboard_activos", rec_act)


def ejecutar(mod):
    """Corre main() del pipeline. Si aborta, devuelve lo capturado hasta ese punto."""
    try:
        mod.main()
    except SystemExit as e:
        REC["errores"].append(f"main() hizo sys.exit({e.code}).")
    except Exception:
        REC["errores"].append("main() lanzó excepción:\n" + traceback.format_exc())


