def hoja(nombre):
    ws = wb.create_sheet(nombre)
    ws.sheet_view.showGridLines = False
    return ws


def headers(ws, row, cols, widths):
    for j, t in enumerate(cols, 1):
        c = ws.cell(row=row, column=j, value=t)
        c.font = F_HEAD; c.fill = FILL_HEAD; c.alignment = AC; c.border = BORDER
    for j, w in enumerate(widths, 1):
        ws.column_dimensions[get_column_letter(j)].width = w
    ws.freeze_panes = ws.cell(row=row + 1, column=1)


def fila(ws, row, vals, fmts=None, aligns=None, fills=None):
    for j, v in enumerate(vals, 1):
        c = ws.cell(row=row, column=j, value=v)
        c.font = F_BODY; c.border = BORDER
        c.alignment = (aligns[j - 1] if aligns else AL)
        if fmts and fmts[j - 1]:
            c.number_format = fmts[j - 1]
        if fills and fills[j - 1]:
            c.fill = fills[j - 1]


