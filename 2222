# Recalculamos scores y regiones FEN desde cero para contrastar contra los
# dashboards y dejar evidencia de que los números cuadran.

def recompute_scores(districts, exp_clase):
    """Score CENEPRED por emisor ponderado por plata distrital (réplica de calcScores())."""
    tot, perd = {}, {}
    for d in districts or []:
        acc = {}
        for a in d.get("aportes", []):
            m = a.get("monto", 0) or 0
            if m > 0:
                acc[a["emisor"]] = acc.get(a["emisor"], 0) + m
        for e, m in acc.items():
            tot[e] = tot.get(e, 0) + m
            perd.setdefault(e, []).append(
                (d.get("score_mm"), d.get("score_inu"), d.get("score_seq"), m))
    out = {}
    for e, T in tot.items():
        amm = ainu = aseq = 0.0
        for mm, inu, seq, m in perd[e]:
            f = (m / T) if T else 0
            amm  += f * (mm  if isinstance(mm,  (int, float)) else 0)
            ainu += f * (inu if isinstance(inu, (int, float)) else 0)
            aseq += f * (seq if isinstance(seq, (int, float)) else 0)
        out[e] = {
            "mm":     round(amm,  2),
            "inu":    round(ainu, 2),
            "seq":    round(aseq, 2),
            "global": round((amm + ainu + aseq) / 3, 2),
        }
    return out


def recompute_region(districts, fen_dep, region_dep):
    """AUM por (Región - Categoría) para la sección Regiones del dashboard FEN."""
    grupos = {}
    for d in districts or []:
        depn = _norm(d.get("dep", ""))
        reg  = (region_dep or {}).get(depn)
        cat  = (fen_dep    or {}).get(depn)
        if not reg or d.get("nivel") not in (1, 2, 3, 4, 5):
            continue
        label = f"{reg} - {cat}" if cat else reg
        g = grupos.setdefault(label, {"aum": 0.0, "emp": {}})
        for a in d.get("aportes", []):
            m = a.get("monto", 0) or 0
            if m <= 0:
                continue
            g["aum"] += m
            acts = a.get("activos") or []
            n    = len(acts) if acts else 1
            e    = g["emp"].setdefault(a["emisor"], {"n": 0, "aum": 0.0})
            e["n"]   += n
            e["aum"] += m
    return grupos


