    rr = 4

    def check(nombre, ok, detalle):
        global rr
        fila(ws, rr, [nombre, "PASA" if ok else "REVISAR", detalle],
             aligns=[AL, AC, AL],
             fills=[None, OK_FILL if ok else BAD_FILL, None])
        rr += 1

    # 1) AUM repartido == AUM total empresa
    peor = 0.0; worst_emp = ""
    for bm in REC["build_model"]:
        dfa = bm["df_assign"]; exp = bm["exp"]
        if dfa is None:
            continue
        asign = {}
        for _, row in dfa.iterrows():
            asign[row["empresa"]] = asign.get(row["empresa"], 0.0) + float(row.get("exposicion", 0) or 0)
        for e, total_emp in exp.items():
            diff = abs(asign.get(e, 0.0) - float(total_emp or 0))
            if diff > peor:
                peor, worst_emp = diff, e
    check("Suma del AUM repartido = AUM total de la empresa", peor <= TOL_ABS,
          f"Máxima diferencia S/ {peor:,.2f} (empresa: {worst_emp}). Tolerancia S/ {TOL_ABS:,.0f}.")

    # 2) build_model capturado
    check("Pipeline capturado (build_model registrado)", len(REC["build_model"]) > 0,
          f"{len(REC['build_model'])} sector(es) capturado(s).")

    # 3) districts capturados
    check("Districts finales capturados", len(districts) > 0,
          f"{len(districts)} distritos.")

    # 4) Pesos de regiones suman 100%
    fa = REC.get("fen_apoyo")
    fen_dep, _, region_dep = (fa if fa and len(fa) == 3 else ({}, [], {}))
    grupos = recompute_region(districts, fen_dep, region_dep)
    total  = sum(g["aum"] for g in grupos.values())
    suma   = sum((g["aum"] / total) for g in grupos.values()) if total else 0
    check("Sección Regiones: pesos suman 100%",
          abs(suma - 1.0) * 100 <= TOL_PCT if total else False,
          f"Suma de pesos = {suma * 100:.2f}% (tolerancia {TOL_PCT}pp).")

