URL_BBVA = (
    "https://www.bbvaresearch.com/buscador/"
    "?dc:coverage@@@skos:prefLabel=Per%C3%BA@es"
)
FILTRO_TITULO_BBVA = "Perú | Seguimiento al consumo con datos en tiempo real"


def scrape_bbva_consumo() -> pd.DataFrame:
    """
    Navega con Selenium a BBVA Research, hace scroll completo
    y extrae cards de publicaciones sobre Perú.
    """
    service = Service(executable_path=CHROMEDRIVER_PATH)
    options = webdriver.ChromeOptions()
    options.add_argument("--start-maximized")
    driver = webdriver.Chrome(service=service, options=options)

    try:
        driver.get(URL_BBVA)
        time.sleep(5)

        # Scroll infinito hasta llegar al fondo
        last_height = driver.execute_script("return document.body.scrollHeight")
        while True:
            driver.execute_script("window.scrollTo(0, document.body.scrollHeight);")
            time.sleep(3)
            new_height = driver.execute_script("return document.body.scrollHeight")
            if new_height == last_height:
                break
            last_height = new_height

        cards = driver.find_elements(By.CSS_SELECTOR, "article.shortcode_card")
        print(f"  📄 BBVA Research: {len(cards)} cards encontrados")

        datos = []
        for card in cards:
            try:
                titulo = card.find_element(By.CSS_SELECTOR, "h3.cardTitulo").text
                fecha  = card.find_element(By.CSS_SELECTOR, "p.cardFecha").text
                link   = card.find_element(
                    By.CSS_SELECTOR, "a.shortcode_card_container"
                ).get_attribute("href")
                datos.append({"fecha": fecha, "titulo": titulo, "link": link})
            except Exception as exc:
                print(f"    ⚠️  Error en card: {exc}")

    finally:
        driver.quit()

    df = pd.DataFrame(datos)
    return df


