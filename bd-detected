def scrape_boletin_minero() -> pd.DataFrame:
    """Boletín Estadístico Minero – gob.pe colecciones."""
    url  = "https://www.gob.pe/institucion/minem/colecciones/6-boletin-estadistico-minero"
    resp = requests.get(url, headers=HEADERS)
    resp.raise_for_status()
    soup = BeautifulSoup(resp.text, "html.parser")

    contenedor = soup.find("div", class_="w-full js-official-documents-search-results")
    items = contenedor.find_all("div", class_="col-md-6 py-2")

    datos = []
    for item in items:
        card = item.find("div", class_=(
            "p-4 shadow-campaign-card border-b-5 border-black h-full flex flex-col justify-between"
        ))
        if not card:
            continue

        fecha_tag = card.find("div", class_="border-b border-gray-700 pb-2 font-medium mb-3")
        a_tag     = card.find("a", class_="leading-6 font-bold underline")
        formatos  = card.find("div", class_="mt-3 leading-5 text-sm")

        datos.append({
            "fecha":       fecha_tag.get_text(strip=True) if fecha_tag else None,
            "titulo":      a_tag.get_text(strip=True) if a_tag else None,
            "link":        "https://www.gob.pe" + a_tag["href"] if a_tag else None,
            "formatos":    formatos.get_text(strip=True) if formatos else None,
        })

    df = pd.DataFrame(datos)[["fecha", "titulo"]].dropna().reset_index(drop=True)
    print(f"  📄 Boletín Minero: {len(df)} registros")
    return df


def scrape_produccion_minera() -> pd.DataFrame:
    """Producción Minera – gob.pe informes-publicaciones."""
    url  = "https://www.gob.pe/institucion/minem/informes-publicaciones/5472883-produccion-minera"
    resp = requests.get(url, headers=HEADERS)
    resp.raise_for_status()
    soup = BeautifulSoup(resp.text, "html.parser")

    contenedor = soup.find("div", class_="js-search-results")
    cards = contenedor.find_all(
        "div", class_="shadow-campaign-card flex-col border-1 border-blue-300"
    )

    datos = []
    for card in cards:
        h3       = card.find("h3", class_="text-base font-bold mb-4")
        link_tag = card.find("a", class_="track-ga-click")
        datos.append({
            "fecha": h3.get_text(strip=True) if h3 else None,
            "link":  link_tag["href"] if link_tag else None,
        })

    df = pd.DataFrame(datos).dropna(subset=["fecha"]).reset_index(drop=True)
    print(f"  📄 Producción Minera: {len(df)} registros")
    return df


def scrape_inversion_minera() -> pd.DataFrame:
    """Inversión Minera – gob.pe informes-publicaciones."""
    url  = "https://www.gob.pe/institucion/minem/informes-publicaciones/3614950-inversion-minera"
    resp = requests.get(url, headers=HEADERS)
    resp.raise_for_status()
    soup = BeautifulSoup(resp.text, "html.parser")

    contenedor = soup.find("div", class_="js-search-results")
    cards = contenedor.find_all(
        "div", class_="shadow-campaign-card flex-col border-1 border-blue-300"
    )

    datos = []
    for card in cards:
        h3  = card.find("h3", class_="text-base font-bold mb-4")
        btn = card.find("a", class_="btn btn--secondary download underline")
        fb  = card.find("a", class_="track-ga-click underline")

        link = None
        if btn and btn.has_attr("href"):
            link = btn["href"]
        elif fb and fb.has_attr("href"):
            link = fb["href"]

        datos.append({
            "fecha": h3.get_text(strip=True) if h3 else None,
            "link":  link,
        })

    df = pd.DataFrame(datos).dropna(subset=["fecha"]).reset_index(drop=True)
    print(f"  📄 Inversión Minera: {len(df)} registros")
    return df


