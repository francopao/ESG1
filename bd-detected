def detectar_nuevos(df_nuevo: pd.DataFrame,
                    df_viejo: pd.DataFrame | None,
                    nombre_fuente: str) -> pd.DataFrame:
    """
    Compara df_nuevo con df_viejo usando las columnas comunes.
    Devuelve sólo las filas que son nuevas (left_only en el merge outer).
    Agrega la columna 'fuente' con nombre_fuente.
    """
    if df_viejo is None or df_viejo.empty:
        df_nuevas = df_nuevo.copy()
    else:
        cols = list(set(df_nuevo.columns) & set(df_viejo.columns))
        nuevo_str = df_nuevo[cols].astype(str)
        viejo_str = df_viejo[cols].astype(str)

        merged = nuevo_str.merge(viejo_str, how="outer", indicator=True)
        df_nuevas = (
            merged[merged["_merge"] == "left_only"]
            .drop(columns="_merge")
            .reset_index(drop=True)
        )

    if not df_nuevas.empty:
        df_nuevas["fuente"] = nombre_fuente
        print(f"\n🚨 ALERTA [{nombre_fuente}]: {len(df_nuevas)} fila(s) nueva(s)")
        print(df_nuevas.to_string(index=False))
    else:
        print(f"\n✅ [{nombre_fuente}]: sin cambios")

    return df_nuevas


def leer_historico(ruta: str, sheet_name=0) -> pd.DataFrame | None:
    """Lee el Excel histórico. Devuelve None si no existe o falla la lectura."""
    if not os.path.exists(ruta):
        print(f"📁 Primera ejecución – no existe histórico: {os.path.basename(ruta)}")
        return None
    try:
        df = pd.read_excel(ruta, sheet_name=sheet_name, engine="openpyxl")
        print(f"📂 Histórico cargado: {os.path.basename(ruta)}")
        return df
    except Exception as exc:
        print(f"⚠️  Error leyendo histórico ({os.path.basename(ruta)}): {exc}")
        return None


def construir_tabla_html(filas: list[dict]) -> str:
    """
    Recibe lista de dicts con claves: fuente, fecha, titulo, link (opcionales).
    Devuelve una tabla HTML estilizada para el cuerpo del correo.
    """
    estilos_tabla = (
        "border-collapse:collapse; width:100%; font-family:Calibri,Arial,sans-serif;"
        "font-size:13px;"
    )
    estilos_th = (
        "background:#1F4E79; color:#FFFFFF; padding:8px 12px;"
        "text-align:left; font-weight:bold;"
    )
    estilos_td = "padding:7px 12px; border-bottom:1px solid #D9D9D9;"
    estilos_td_alt = "padding:7px 12px; border-bottom:1px solid #D9D9D9; background:#F2F7FB;"

    html = f'<table style="{estilos_tabla}">\n'
    html += "  <thead><tr>\n"
    for col in ["Fuente", "Fecha", "Título", "Link"]:
        html += f'    <th style="{estilos_th}">{col}</th>\n'
    html += "  </tr></thead>\n  <tbody>\n"

    for i, fila in enumerate(filas):
        td = estilos_td_alt if i % 2 else estilos_td
        fuente = fila.get("fuente", "—")
        fecha  = fila.get("fecha",  "—")
        titulo = fila.get("titulo", "—") or "—"
        link   = fila.get("link",   "") or ""
        link_html = f'<a href="{link}" style="color:#0563C1;">Ver publicación</a>' if link else "—"
        html += f"  <tr>\n"
        html += f'    <td style="{td}">{fuente}</td>\n'
        html += f'    <td style="{td}">{fecha}</td>\n'
        html += f'    <td style="{td}">{titulo}</td>\n'
        html += f'    <td style="{td}">{link_html}</td>\n'
        html += "  </tr>\n"

    html += "  </tbody>\n</table>\n"
    return html


