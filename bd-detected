def enviar_correo_html(asunto: str, cuerpo_intro: str, filas_alertas: list[dict]) -> None:
    """
    Arma y envía un correo HTML con tabla de alertas y firma corporativa.

    Parámetros:
        asunto        – Línea de asunto del correo
        cuerpo_intro  – Párrafo introductorio antes de la tabla
        filas_alertas – Lista de dicts [{fuente, fecha, titulo, link}, ...]
    """
    tabla_html  = construir_tabla_html(filas_alertas)
    firma_html  = construir_firma_html()

    html_body = f"""
<html><body style="font-family:Calibri,Arial,sans-serif; font-size:13px;">
  <p>{cuerpo_intro}</p>
  {tabla_html}
  <p style="margin-top:12px;">Por favor revisar e incorporar en los insumos del modelo.</p>
  {firma_html}
</body></html>
"""

    outlook = win32.Dispatch("Outlook.Application")
    mail    = outlook.CreateItem(0)

    mail.To      = "; ".join(CORREOS_TO)
    mail.CC      = "; ".join(CORREOS_CC)
    mail.Subject = asunto
    mail.HTMLBody = html_body

    # Logo embebido
    if os.path.exists(LOGO_PATH):
        att = mail.Attachments.Add(LOGO_PATH)
        att.PropertyAccessor.SetProperty(
            "http://schemas.microsoft.com/mapi/proptag/0x3712001F",
            "logo_integra"
        )

    mail.Send()
    print("✅ Correo enviado correctamente")


def filas_de_alertas(lista_dfs: list[pd.DataFrame]) -> list[dict]:
    """Convierte lista de DataFrames de alertas en lista de dicts para la tabla."""
    filas = []
    for df in lista_dfs:
        for _, row in df.iterrows():
            filas.append({
                "fuente": row.get("fuente", ""),
                "fecha":  row.get("fecha",  ""),
                "titulo": row.get("titulo", ""),
                "link":   row.get("link",   ""),
            })
    return filas


