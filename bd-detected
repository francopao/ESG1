def url_sbs_existe(url: str) -> bool:
    """Verifica si la URL SBS responde con 200."""
    try:
        r = requests.head(url, headers=HEADERS, timeout=5)
        return r.status_code == 200
    except Exception:
        return False


def encontrar_ultimo_sbs(indicador: str) -> dict | None:
    """
    Recorre años (actual → actual-4) y meses (dic → ene)
    hasta encontrar el archivo XLS más reciente en la SBS.
    """
    anio_actual = datetime.now().year
    for anio in range(anio_actual, anio_actual - 5, -1):
        for cod_mes, nombre_mes in MESES_SBS:
            archivo = f"{indicador}-{cod_mes}{anio}.XLS"
            url = (
                f"https://intranet2.sbs.gob.pe/estadistica/financiera"
                f"/{anio}/{nombre_mes}/{archivo}"
            )
            if url_sbs_existe(url):
                return {
                    "fecha":       f"{nombre_mes} {anio}",
                    "titulo":      f"{indicador} – {nombre_mes} {anio}",
                    "link":        url,
                    "descripcion": f"{indicador} – {nombre_mes} {anio}",
                }
    return None


