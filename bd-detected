URL_INE_IPI = (
    "https://www.ine.gob.cl/estadisticas-por-tema/"
    "industria-energia-y-construccion/indice-de-produccion-industrial"
)
URL_OSITRAN = "https://www.ositran.gob.pe/anterior/publicaciones/boletin-estadistico/"

FOLDER_INE = "fc62c4c1-8e79-4a42-bfc6-b37238816f98"   # ID carpeta boletines INE


def scrape_ipi_chile() -> pd.DataFrame:
    """
    Navega el portal INE Chile con Selenium y extrae los links
    de boletines del IPI del año actual.
    """
    driver = webdriver.Chrome()
    wait   = WebDriverWait(driver, 15)

    try:
        driver.get(URL_INE_IPI)

        # Abrir carpeta "Boletines"
        boletines = wait.until(EC.element_to_be_clickable((
            By.CSS_SELECTOR,
            f'div.navPrincipalDescargas[data-folder="{FOLDER_INE}"]'
        )))
        boletines.click()

        # Seleccionar año actual
        anio_actual = str(datetime.now().year)
        anio_elem = wait.until(EC.element_to_be_clickable((
            By.XPATH,
            f'//div[contains(@class,"categoriaDescarga") and text()="{anio_actual}"]'
        )))
        anio_elem.click()
        time.sleep(2)

        links = driver.find_elements(By.CSS_SELECTOR, "a.widArchNavArchivoDescarga")
        hrefs = [lnk.get_attribute("href") for lnk in links]

    finally:
        driver.quit()

    datos = []
    for href in hrefs:
        decoded = urllib.parse.unquote(href.lower())
        match = re.search(
            r"(enero|febrero|marzo|abril|mayo|junio|julio|agosto|"
            r"septiembre|octubre|noviembre|diciembre)-(\d{4})",
            decoded
        )
        fecha = f"{match.group(1)} {match.group(2)}" if match else None
        datos.append({"titulo": "Índice de Producción Industrial", "fecha": fecha})

    df = pd.DataFrame(datos)
    print(f"  📄 IPI Chile: {len(df)} registros")
    return df


def scrape_ositran() -> pd.DataFrame:
    """
    Navega el portal OSITRAN con Selenium y extrae boletines del año actual.
    """
    driver = webdriver.Chrome()
    wait   = WebDriverWait(driver, 15)

    try:
        driver.get(URL_OSITRAN)
        anio_actual = str(datetime.now().year)

        tab = wait.until(EC.element_to_be_clickable((
            By.XPATH,
            f'//ul[contains(@class,"nav-tabs")]//a[text()="{anio_actual}"]'
        )))
        tab.click()

        wait.until(EC.presence_of_element_located((By.ID, f"tab-{anio_actual}")))
        time.sleep(1)

        elementos = driver.find_elements(
            By.CSS_SELECTOR, f"#tab-{anio_actual} div.bole-item h2 a"
        )

        datos = []
        for el in elementos:
            titulo_raw = el.text
            match = re.search(r"(\w+)\s(\d{4})", titulo_raw.lower())
            fecha = f"{match.group(1)} {match.group(2)}" if match else None
            datos.append({"titulo": "Boletín Estadístico OSITRAN", "fecha": fecha})

    finally:
        driver.quit()

    df = pd.DataFrame(datos)
    print(f"  📄 OSITRAN Perú: {len(df)} registros")
    return df


