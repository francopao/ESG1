```javascript
// ======================================================================
//  VISTA ESTRATÉGICA — A) Peligro × Mitigante  B) Concentración (Pareto)
// ======================================================================
let MIT_POLARIDAD = 'proteccion';        // 'proteccion' | 'residual'
const MIT_NUM = {'Bajo':1,'Medio':2,'Alto':3};

function riesgoPorEmisor(){
  const scores = calcScores();           // score global por emisor (class-aware)
  const aum = {};
  D.forEach(d=>{ (d.ap||[]).forEach(a=>{
    const m=a.m*classFrac(a.e); if(m>0) aum[a.e]=(aum[a.e]||0)+m; }); });
  const out=[];
  Object.keys(aum).forEach(e=>{
    const sc = scores[e]? scores[e].global : 0;
    out.push({emisor:e, sector:EMP_SECTOR[e]||'', aum:aum[e],
              score:sc, plataRiesgo:aum[e]*sc, mit:getMitigante(e)});
  });
  return out;
}
function maxAum(datos){ return Math.max.apply(null,datos.map(r=>r.aum)); }

let _mitPolWired=false;
function buildEstrategia(){
  if(!_mitPolWired){ const c=document.getElementById('chkMitPol');
    if(c){ c.onchange=()=>{ MIT_POLARIDAD=c.checked?'residual':'proteccion'; buildBubbleMit(); };
      _mitPolWired=true; } }
  buildBubbleMit(); buildPareto();
}

function buildBubbleMit(){
  const el=document.getElementById('bubbleMit'); if(!el) return;
  const datos=riesgoPorEmisor().filter(r=>r.aum>0);
  const sectores=[...new Set(datos.map(r=>r.sector))];
  const jitter=()=> (Math.random()-0.5)*0.28;
  const mx=maxAum(datos)||1;
  const traces=sectores.map(sec=>{
    const sub=datos.filter(r=>r.sector===sec);
    return { type:'scatter', mode:'markers', name:sec||'(s/sector)',
      x:sub.map(r=>(MIT_NUM[r.mit]||0)+jitter()),
      y:sub.map(r=>r.score),
      text:sub.map(r=>r.emisor),
      customdata:sub.map(r=>[r.mit||'s/d', fmtMonto(r.aum), r.score.toFixed(2)]),
      hovertemplate:'<b>%{text}</b><br>Mitigante: %{customdata[0]}'+
        '<br>Peligro (score): %{customdata[2]}<br>AUM mapeado: %{customdata[1]}<extra>'+(sec||'')+'</extra>',
      marker:{ size:sub.map(r=>Math.max(8,Math.min(46,8+34*Math.sqrt(r.aum/mx)))),
               color:SEC_COLOR[sec]||'#555', line:{color:'#fff',width:1}, opacity:.82 } };
  });
  const xPel = (MIT_POLARIDAD==='proteccion') ? [-0.6,1.5] : [2.5,3.6];
  const shapes=[{type:'rect',xref:'x',yref:'y',x0:xPel[0],x1:xPel[1],y0:3,y1:5.3,
    fillcolor:'rgba(192,57,43,.08)',line:{width:0},layer:'below'}];
  const anns=[{x:(xPel[0]+xPel[1])/2,y:5.15,xref:'x',yref:'y',
    text:'Prioridad: peligro alto + mitigación baja',showarrow:false,
    font:{size:11,color:'#c0392b'},xanchor:'center'}];
  const layout={ margin:{l:54,r:18,t:14,b:54}, paper_bgcolor:'#fff', plot_bgcolor:'#fff',
    hovermode:'closest', shapes, annotations:anns,
    legend:{orientation:'h',y:-0.16,font:{size:10}},
    xaxis:{title:{text:'Mitigante',font:{size:12,color:AFP.azul}}, range:[-0.7,3.7],
      tickvals:[0,1,2,3], ticktext:['s/d','Bajo','Medio','Alto'], showgrid:false, zeroline:false},
    yaxis:{title:{text:'Peligro CENEPRED (score global pond. 0–5)',font:{size:12,color:AFP.azul}},
      range:[0,5.4], dtick:1, gridcolor:'#eef0f5', zeroline:false} };
  Plotly.react('bubbleMit',traces,layout,{displayModeBar:false,responsive:true});
}

function buildPareto(){
  const el=document.getElementById('paretoRisk'); if(!el) return;
  let datos=riesgoPorEmisor().filter(r=>r.plataRiesgo>0).sort((a,b)=>b.plataRiesgo-a.plataRiesgo);
  const total=datos.reduce((s,r)=>s+r.plataRiesgo,0)||1;
  let acc=0; const cum=datos.map(r=>{acc+=r.plataRiesgo; return acc/total*100;});
  let n80=cum.findIndex(v=>v>=80); n80=n80<0?datos.length:n80+1;
  const x=datos.map(r=>r.emisor);
  const bars={type:'bar',x:x,y:datos.map(r=>r.plataRiesgo),
    marker:{color:datos.map(r=>SEC_COLOR[r.sector]||AFP.azul)}, yaxis:'y',
    customdata:datos.map(r=>[r.sector, fmtMonto(r.aum), r.score.toFixed(2)]),
    hovertemplate:'<b>%{x}</b> (%{customdata[0]})<br>Plata en riesgo: %{y:,.0f}'+
      '<br>AUM mapeado: %{customdata[1]} · score %{customdata[2]}<extra></extra>'};
  const line={type:'scatter',mode:'lines+markers',x:x,y:cum,yaxis:'y2',
    line:{color:'#c0392b',width:2},marker:{size:5},
    hovertemplate:'%{x}<br>Acumulado: %{y:.1f}%<extra></extra>'};
  const shapes=[{type:'line',xref:'paper',yref:'y2',x0:0,x1:1,y0:80,y1:80,
    line:{color:'#7E8083',width:1,dash:'dot'}}];
  const anns=[{x:0.99,y:80,xref:'paper',yref:'y2',text:'80%',showarrow:false,
    font:{size:10,color:'#7E8083'},xanchor:'right',yanchor:'bottom'},
    {x:0.5,y:1.06,xref:'paper',yref:'paper',xanchor:'center',showarrow:false,
     text:'El 80% de la plata-en-riesgo se concentra en '+n80+' de '+datos.length+' emisor(es)',
     font:{size:11,color:AFP.azul}}];
  const layout={margin:{l:62,r:54,t:30,b:96},paper_bgcolor:'#fff',plot_bgcolor:'#fff',
    showlegend:false, shapes, annotations:anns, bargap:.3,
    xaxis:{tickangle:-40,tickfont:{size:9},automargin:true},
    yaxis:{title:{text:'Plata en riesgo (S/ × score)',font:{size:11,color:AFP.azul}},
      gridcolor:'#eef0f5',zeroline:false},
    yaxis2:{title:{text:'% acumulado',font:{size:11,color:'#c0392b'}},overlaying:'y',
      side:'right',range:[0,105],zeroline:false,showgrid:false}};
  Plotly.react('paretoRisk',[bars,line],layout,{displayModeBar:false,responsive:true});
}
```

