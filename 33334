def calculo_Aum(df, fondos, afps):
    fila_header = _localizar_fila_encabezado(df, ["Fecha"], max_filas_busqueda=15)
    lista_df = []

    # Calculo del AUM de cada fondo por AFP
    for fondo in fondos:
        for afp in afps:
            df_temp = df.copy()
            df_temp = df_temp[fila_header:]
            df_temp = df_temp.transpose()
            lista_aum = ['Fecha', f'{afp}-FONDO{fondo}']
            df_ = df_temp[df_temp[fila_header].isin(lista_aum)]
            df_ = df_.transpose()

            df_.columns = df_.iloc[0].to_list()
            df_ = df_.drop(fila_header, axis=0)

            df_['Fecha'] = pd.to_datetime(df_['Fecha'], errors='coerce')
            df_.set_index('Fecha', inplace=True)
            df_ = df_.set_axis([f'{afp}_F{fondo}'], axis=1)
            df_ = df_['2014-12-30':]
            # DECISIÓN NEGOCIO: "ND"/NaN -> 0. Se mantiene igual que el
            # original para no cambiar el resultado financiero; ver
            # changelog y diagnóstico para la discusión de riesgo.
            df_ = df_.replace("ND", 0).fillna(0).astype(np.float64)
            lista_df.append(df_)

    df_final = pd.concat(lista_df, axis=1)

    # Calculo del Market Share de cada AFP
    df_final['Total'] = df_final.sum(axis=1)

    for afp in afps:
        df_final[f'{afp}_MF'] = df_final.filter(like=f'{afp}_').sum(axis=1)
        df_final[f'{afp}_Share'] = df_final[f'{afp}_MF'] / df_final['Total']

    # Calculo de los AUM Ex-Sistema de cada afp
    combinaciones = {
        'EXIN': ['HA', 'PF', 'RI'],
        'EXHA': ['IN', 'PF', 'RI'],
        'EXPF': ['IN', 'HA', 'RI'],
        'EXRI': ['IN', 'PF', 'HA']
    }

    for fondo in fondos:
        for nuevo_col, cols in combinaciones.items():
            df_final[f'{nuevo_col}_F{fondo}'] = df_final[[f'{col}_F{fondo}' for col in cols]].sum(axis=1)

    # Calculo del AUM total de cada AFP
    df_final['Aum_IN'] = df_final['IN_F1'] + df_final['IN_F2'] + df_final['IN_F3']
    df_final['Aum_HA'] = df_final['HA_F1'] + df_final['HA_F2'] + df_final['HA_F3']
    df_final['Aum_PF'] = df_final['PF_F1'] + df_final['PF_F2'] + df_final['PF_F3']
    df_final['Aum_RI'] = df_final['RI_F1'] + df_final['RI_F2'] + df_final['RI_F3']

    # Se elimina la columna "Total"
    df_final.drop(columns=['Total'], inplace=True)

    return df_final


