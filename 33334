### DQ_IN
# %%
def DQ_IN(df1, DQ_IN_BD, ListaIN, ListaUsados):
    fila_header = _localizar_fila_encabezado(df1, ["Fondo", "Dato", "Fecha", "SBS"])
    # Se eliminan las primeras filas del documento que no serán usadas
    df1 = df1.drop(df1.index[list(range(0, fila_header))])
    df1 = df1.transpose()
    df1 = df1.rename(columns={fila_header: "Isins"})
    filtrada = df1[df1["Isins"].isin(ListaIN)]
    filtrada = filtrada.transpose()
    filtrada1 = filtrada
    filtrada1.columns = filtrada.iloc[0].to_list()
    filtrada = filtrada1[1:]

    DQ_IN_FECHAS = DQ_IN_BD["Fecha"][::-1].copy()
    DQ_IN_UltimaFecha = DQ_IN_FECHAS.iloc[0]

    log.info("DQ IN: última fecha en base = %s", DQ_IN_UltimaFecha)

    Qest_DQ_IN_Fechas = filtrada["Fecha"].values.tolist()

    if DQ_IN_UltimaFecha not in Qest_DQ_IN_Fechas:
        raise ValueError(
            f"La última fecha de la base de Integra ({DQ_IN_UltimaFecha}) no "
            f"existe en las fechas del QEST (DQ_IN). Esto suele significar que "
            f"el QEST no está actualizado hasta esa fecha, o que hay un hueco "
            f"entre la base y el QEST. Actualiza QEST_BD.xlsm antes de correr. "
            f"Rango de fechas disponibles en QEST: "
            f"{Qest_DQ_IN_Fechas[0]} ... {Qest_DQ_IN_Fechas[-1]}."
        )

    # +BLOQUE_FILAS_DQ_IN: cada fecha trae 9 filas (3 fondos x 3 tipos de
    # dato Q/PxQ/%Fondo) antes de llegar a la fecha siguiente. Ver
    # constante definida al inicio del script.
    ubifechas = Qest_DQ_IN_Fechas.index(DQ_IN_UltimaFecha) + BLOQUE_FILAS_DQ_IN
    Nuevos_DQ_IN = filtrada[ubifechas::]
    Nuevos_DQ_IN = Nuevos_DQ_IN.reset_index()
    Nuevos_DQ_IN = Nuevos_DQ_IN.drop("index", axis=1)
    Nuevos_DQ_IN = Nuevos_DQ_IN.loc[Nuevos_DQ_IN['Dato'] == "Q"]

    LISTO = pd.concat([DQ_IN_BD, Nuevos_DQ_IN]).reset_index(drop=True)

    return LISTO


