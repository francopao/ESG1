# ==============================================================================
# 1) DAMAGE RATIOS CON FUENTE  (ningún número sin origen citado)
# ==============================================================================

# --- INUNDACIÓN: curvas Huizinga JRC, columna "Centr&South AMERICA" -----------
# FRAMEWORK: Huizinga, De Moel & Szewczyk (2017), JRC Technical Report; usadas en
#            Roncalli/Amundi (2026) como damage functions por tipo de activo.
# CALIBRACIÓN: valores extraídos del archivo del proyecto
#            global_flood_depth-damage_functions (hoja "Damage functions",
#            columna Centr&South AMERICA). profundidad[m] -> fracción de daño.
# LÍMITE: curva CONTINENTAL (no peruana); cóncava-saturante (no convexa). Es DR
#            TRANSFERIDO, no calibrado localmente.
HUIZINGA_SA = {
    "Residential": {0.0: 0.0, 0.5: 0.491, 1.0: 0.711, 1.5: 0.842, 2.0: 0.949, 3.0: 0.984, 4.0: 1.0},
    "Commercial":  {0.0: 0.0, 0.5: 0.611, 1.0: 0.840, 1.5: 0.924, 2.0: 0.992, 3.0: 1.0,   4.0: 1.0},
    "Industrial":  {0.0: 0.0, 0.5: 0.667, 1.0: 0.889, 1.5: 0.947, 2.0: 1.0,   3.0: 1.0,   4.0: 1.0},
    "Transport":   {0.0: 0.0, 0.5: 0.088, 1.0: 0.175, 1.5: 0.596, 2.0: 0.842, 3.0: 1.0,   4.0: 1.0},
}

# Mapeo sector de cartera -> tipo de activo Huizinga.
# FRAMEWORK: enfoque asset-level sobre proxy de sede (MSCI 2025).
# LÍMITE: aproximación por sector; un activo concreto puede diferir.
SECTOR_ASSET_TYPE = {
    "Minería": "Industrial", "Construcción": "Industrial", "Utilities": "Industrial",
    "Energía": "Industrial", "Consumo": "Commercial", "Salud": "Commercial",
    "Educación": "Commercial", "Infraestructura": "Transport",
}
ASSET_TYPE_DEFAULT = "Industrial"

# Proxy DECLARADO score CENEPRED -> tirante (m), usado SOLO cuando no hay EVAR.
# Es un proxy explícito (no un dato): el usuario autorizó usar el score como
# proxy de periodo de retorno/profundidad y declararlo. DR_tipo => "proxy declarado".
SCORE_DEPTH_PROXY_M = {1: 0.5, 2: 1.0, 3: 1.5, 4: 2.0, 5: 3.0}

# Departamentos costa norte para la bandera ENSO (modulador, NO multiplicador).
COSTA_NORTE_DEPS = {"PIURA", "LAMBAYEQUE", "LA LIBERTAD", "TUMBES", "ICA"}
# Región con inventario de MM/aluviones disponible (Valderrama, Cordillera Blanca).
MM_INVENTARIO_DEPS = {"ANCASH"}

# Etiquetas de confianza (jerarquía de incertidumbre; Hain et al. 2021).
TIER_CAL, TIER_TR, TIER_PROXY, TIER_NA = "calibrado", "transferido", "proxy declarado", "sin dato disponible"


# ==============================================================================
# 2) UTILIDADES
# ==============================================================================

def _norm(s):
    if s is None:
        return ""
    s = str(s).strip().upper()
    s = "".join(c for c in unicodedata.normalize("NFKD", s) if not unicodedata.combining(c))
    return re.sub(r"\s+", " ", re.sub(r"[^A-Z0-9 ]", " ", s)).strip()


def _split_rv_rf(emisor, exp_clase):
    """Fracción RV/RF (split uniforme en geografía, como el pipeline). FRAMEWORK:
    diferenciación RF/RV (Azzone 2025)."""
    d = exp_clase.get(emisor)
    if not d or d.get("TOTAL", 0) <= 0:
        return 1.0, 0.0
    t = d["TOTAL"]
    return d.get("RENTA VARIABLE", 0.0) / t, d.get("RENTA FIJA", 0.0) / t


def _huizinga_dr(asset_type, depth_m):
    """Interpola linealmente la curva Huizinga SA para un tipo de activo y tirante."""
    curve = HUIZINGA_SA.get(asset_type, HUIZINGA_SA[ASSET_TYPE_DEFAULT])
    xs = sorted(curve)
    if depth_m <= xs[0]:
        return curve[xs[0]]
    if depth_m >= xs[-1]:
        return curve[xs[-1]]
    for i in range(1, len(xs)):
        if depth_m <= xs[i]:
            x0, x1 = xs[i - 1], xs[i]
            y0, y1 = curve[x0], curve[x1]
            return y0 + (y1 - y0) * (depth_m - x0) / (x1 - x0)
    return curve[xs[-1]]


# ==============================================================================
# 3) ACTIVO / PATRIMONIO POR EMISOR  (para el apalancamiento RV; Merton)
# ==============================================================================

def cargar_activo_patrimonio(risk_path, sheet_val, equiv_canonico):
    """Lee Activo/Patrimonio (cols W/Y de Valorización) por emisor canónico.
    FRAMEWORK: Merton/Azzone 2025. CALIBRACIÓN: estados del emisor en Valorización
    (origen SMV). LÍMITE: valores contables, punto en el tiempo."""
    raw = pd.read_excel(risk_path, sheet_name=sheet_val, header=None, nrows=12)
    hdr = None
    for i in range(min(12, len(raw))):
        j = " | ".join(_norm(v) for v in raw.iloc[i].tolist())
        if "NOMBRE" in j and "ACTIVO" in j:
            hdr = i
            break
    if hdr is None:
        raise ValueError("rf_extension: no se halló encabezado Nombre/Activo en Valorización.")
    df = pd.read_excel(risk_path, sheet_name=sheet_val, header=hdr).dropna(how="all")
    cn = {_norm(c): c for c in df.columns}

    def find(*sets):
        for toks in sets:
            for k, real in cn.items():
                if all(t in k for t in toks):
                    return real
        return None

    c_n = find(["NOMBRE", "G P"], ["NOMBRE"])
    c_a = find(["ACTIVO", "EMISOR"], ["ACTIVO"])
    c_p = find(["PATRIMONIO", "EMISOR"], ["PASTRIMONIO", "EMISOR"], ["PATRIMONIO"], ["PASTRIMONIO"])
    if not all([c_n, c_a, c_p]):
        raise ValueError("rf_extension: faltan columnas Activo/Patrimonio en Valorización.")
    df = df.rename(columns={c_n: "nombre", c_a: "activo", c_p: "patrim"})
    df["activo"] = pd.to_numeric(df["activo"], errors="coerce").fillna(0.0)
    df["patrim"] = pd.to_numeric(df["patrim"], errors="coerce").fillna(0.0)
    eqn = {_norm(k): v for k, v in equiv_canonico.items()}
    out = {}
    for _, r in df.iterrows():
        em = eqn.get(_norm(r["nombre"]))
        if em is None:
            continue
        d = out.setdefault(em, {"activo": 0.0, "patrimonio": 0.0})
        d["activo"] = max(d["activo"], float(r["activo"]))
        d["patrimonio"] = max(d["patrimonio"], float(r["patrim"]))
    return out


# ==============================================================================
# 4) ESTADO ENSO (ICEN como MODULADOR / bandera, NO multiplicador inventado)
# ==============================================================================

def cargar_estado_enso(indic_path):
    """Devuelve el estado ICEN vigente y su percentil histórico. ICEN se usa como
    bandera de contexto, NO como multiplicador (no hay elasticidad calibrada)."""
    est = {"icen": None, "icen_fecha": None, "percentil_hist": None, "alerta_costa_norte": False,
           "nota": "ICEN como modulador/bandera; sin multiplicador (no calibrado)"}
    if indic_path and os.path.exists(indic_path):
        try:
            df = pd.read_excel(indic_path, sheet_name="ICEN")
            cf = next((c for c in df.columns if _norm(c) == "FECHA"), df.columns[0])
            cv = next((c for c in df.columns if _norm(c) == "ICEN"), df.columns[-1])
            df = df.dropna(subset=[cv]).sort_values(cf)
            last = df.iloc[-1]
            v = float(last[cv])
            est["icen"] = round(v, 2)
            est["icen_fecha"] = pd.to_datetime(last[cf]).strftime("%Y-%m")
            est["percentil_hist"] = round((df[cv] <= v).mean() * 100, 1)
            est["alerta_costa_norte"] = v > 1.0   # bandera, no número
        except Exception as e:
            est["nota"] = f"ICEN no leído ({e})."
    return est


# ==============================================================================
# 5) PÉRDIDA ESPERADA  (solo donde hay DR con fuente; resto = SIN DATO)
# ==============================================================================

def calcular_perdida_esperada(districts, exp_clase, emp_sector, activo_patrimonio,
                              canal_indirecto, enso_state, tirante_por_ubigeo=None):
    """Calcula Pérdida Esperada S/ por empresa SOLO para inundación (único hazard
    con DR con fuente: Huizinga SA). MM y sequía/FEN se reportan como banderas
    categóricas o "sin dato", nunca como número inventado.

    Inundación:  PE = Σ_distritos exp_RV × min(1, DR_huizinga(asset,profundidad) × Activo/Patrimonio)
      - DR_huizinga: TRANSFERIDO (curvas SA del archivo JRC).
      - profundidad: tirante EVAR si está en tirante_por_ubigeo (=> transferido),
        si no, score CENEPRED -> SCORE_DEPTH_PROXY_M (=> proxy declarado).
      - apalancamiento RV: Merton/Azzone 2025 (dato: Activo/Patrimonio).
      - RF: K_RF no calibrable con datos PE => porción RF marcada SIN DATO (no suma S/).
    """
    tirante_por_ubigeo = tirante_por_ubigeo or {}
    costa = {_norm(x) for x in COSTA_NORTE_DEPS}
    mm_inv = {_norm(x) for x in MM_INVENTARIO_DEPS}

    acc = {}  # emisor -> agregados
    for d in districts:
        dep = _norm(d.get("dep"))
        for emisor, monto in d.get("empresas", {}).items():
            if not monto or monto <= 0 or emisor in canal_indirecto:
                continue
            a = acc.setdefault(emisor, {
                "sector": emp_sector.get(emisor, ""), "exp_total": 0.0,
                "pe_inu_rv": 0.0, "exp_inu_rv": 0.0, "exp_rf_en_riesgo": 0.0,
                "dr_inu_sumprod": 0.0, "tipo_inu": set(),
                "mm_nivel": 0, "mm_inventario": False, "exp_seq": 0.0,
                "costa_norte": False, "ap_disp": False})
            a["exp_total"] += monto
            frac_rv, frac_rf = _split_rv_rf(emisor, exp_clase)
            ap = activo_patrimonio.get(emisor)
            lev = (ap["activo"] / ap["patrimonio"]) if ap and ap.get("patrimonio", 0) > 0 else None
            a["ap_disp"] = a["ap_disp"] or (lev is not None)
            asset_type = SECTOR_ASSET_TYPE.get(a["sector"], ASSET_TYPE_DEFAULT)
            if dep in costa:
                a["costa_norte"] = True

            # --- INUNDACIÓN (único con DR cuantificable) ---
            sc_inu = d.get("score_inu")
            if sc_inu is not None:
                try:
                    sc_i = int(round(float(sc_inu)))
                except (TypeError, ValueError):
                    sc_i = None
                if sc_i is not None:
                    ub = d.get("ubigeo")
                    if ub in tirante_por_ubigeo:           # tirante real EVAR
                        depth = float(tirante_por_ubigeo[ub]); a["tipo_inu"].add(TIER_TR)
                    else:                                   # proxy declarado
                        depth = SCORE_DEPTH_PROXY_M.get(sc_i)
                        a["tipo_inu"].add(TIER_PROXY)
                    if depth is not None:
                        dr = _huizinga_dr(asset_type, depth)
                        exp_rv = monto * frac_rv
                        dr_rv = min(1.0, dr * lev) if lev is not None else dr
                        a["pe_inu_rv"] += exp_rv * dr_rv
                        a["exp_inu_rv"] += exp_rv
                        a["dr_inu_sumprod"] += exp_rv * dr_rv
                        a["exp_rf_en_riesgo"] += monto * frac_rf   # RF: sin dato (no suma S/)

            # --- MOVIMIENTOS DE MASA (categórico, sin S/) ---
            sc_mm = d.get("score_mm")
            if sc_mm is not None:
                try:
                    a["mm_nivel"] = max(a["mm_nivel"], int(round(float(sc_mm))))
                except (TypeError, ValueError):
                    pass
                if dep in mm_inv:
                    a["mm_inventario"] = True

            # --- SEQUÍA (sin dato concluyente; solo exposición marcada) ---
            if d.get("score_seq") is not None:
                a["exp_seq"] += monto

    # --- armar filas por empresa ---
    filas = []
    for emisor, a in acc.items():
        dr_ef = (a["dr_inu_sumprod"] / a["exp_inu_rv"]) if a["exp_inu_rv"] > 0 else None
        tipo_inu = (TIER_TR if TIER_TR in a["tipo_inu"] else
                    (TIER_PROXY if TIER_PROXY in a["tipo_inu"] else TIER_NA))
        # hazard dominante (entre los que tienen evidencia)
        if a["pe_inu_rv"] > 0:
            dom = "Inundación"
        elif a["mm_nivel"] >= 4 and a["mm_inventario"]:
            dom = "Mov. de Masa (inventario)"
        elif a["mm_nivel"] >= 4:
            dom = "Mov. de Masa (sin inventario)"
        elif a["exp_seq"] > 0:
            dom = "Sequía (sin dato)"
        else:
            dom = "—"
        filas.append({
            "emisor": emisor, "sector": a["sector"], "exp_total": round(a["exp_total"], 2),
            # DR de inundación (lo único cuantificado)
            "dr_fuente": ("Huizinga JRC 2017, Centr&South America, %s"
                          % SECTOR_ASSET_TYPE.get(a["sector"], ASSET_TYPE_DEFAULT)) if a["exp_inu_rv"] > 0 else "—",
            "dr_valor": round(dr_ef, 3) if dr_ef is not None else None,
            "dr_tipo": tipo_inu,
            "perdida_esperada": round(a["pe_inu_rv"], 2),    # solo inundación RV
            "exp_rf_sin_dato": round(a["exp_rf_en_riesgo"], 2),
            "ap_disponible": a["ap_disp"],
            "hazard_dom": dom,
            # banderas categóricas (sin S/)
            "mm_flag": ("alto (inventario Valderrama)" if (a["mm_nivel"] >= 4 and a["mm_inventario"])
                        else "alto (sin inventario local)" if a["mm_nivel"] >= 4
                        else "bajo" if a["mm_nivel"] > 0 else TIER_NA),
            "seq_flag": ("expuesto — sin dato concluyente" if a["exp_seq"] > 0 else TIER_NA),
            "enso_flag": (a["costa_norte"] and enso_state.get("alerta_costa_norte", False)),
        })
    filas.sort(key=lambda r: r["perdida_esperada"], reverse=True)

    # --- canal indirecto (bancos/soberanos/extranjeros) ---
    indirecto = [{"emisor": e, "sector": emp_sector.get(e, ""), "motivo": m}
                 for e, m in canal_indirecto.items()]

    # --- resumen ejecutivo ---
    total_pe = sum(f["perdida_esperada"] for f in filas)
    sin_dato = [f["emisor"] for f in filas if f["perdida_esperada"] == 0]
    resumen = {
        "total_perdida_esperada": round(total_pe, 2),
        "por_hazard": {
            "Inundación": round(total_pe, 2),
            "Mov. de Masa": "sin dato (categórico)",
            "Sequía": "sin dato concluyente",
            "FEN operativo": "sin dato concluyente",
        },
        "empresas_sin_dato_S": sin_dato,
        "n_empresas": len(filas),
        "enso": enso_state,
        "rf_no_cuantificado": round(sum(f["exp_rf_sin_dato"] for f in filas), 2),
    }
    return {"filas": filas, "indirecto": indirecto, "resumen": resumen}


def detectar_canal_indirecto(districts, exp_clase, emp_sector, sector_financiero="Financiero"):
    """Bancos (PD territorial, Chitchumnong 2025; B-2314 sin morosidad => sin dato)
    y emisores sin cruce distrital (soberanos/extranjeros)."""
    presentes = set()
    for d in districts:
        for e, m in d.get("empresas", {}).items():
            if m and m > 0:
                presentes.add(e)
    out = {}
    for e in exp_clase:
        if emp_sector.get(e) == sector_financiero:
            out[e] = "banco — PD territorial (Chitchumnong 2025); morosidad distrital: sin dato"
        elif e not in presentes:
            out[e] = "sin cruce distrital (soberano/extranjero/fondo)"
    return out


