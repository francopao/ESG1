def generar_extension(out_dir, districts, exp_clase, emp_sector,
                      risk_path, sheet_val, equiv_canonico,
                      indic_path=None, tirante_por_ubigeo=None, stamp=None, logfn=print):
    """Pega todo y escribe el HTML compañero. Todo aditivo y de solo lectura."""
    if stamp is None:
        stamp = datetime.now().strftime("%Y%m%d_%H%M")
    ap = cargar_activo_patrimonio(risk_path, sheet_val, equiv_canonico)
    canal = detectar_canal_indirecto(districts, exp_clase, emp_sector)
    enso = cargar_estado_enso(indic_path)
    res = calcular_perdida_esperada(districts, exp_clase, emp_sector, ap, canal, enso,
                                    tirante_por_ubigeo=tirante_por_ubigeo)
    out = os.path.join(out_dir, f"Extension_PerdidaEsperada_{stamp}.html")
    construir_html_companion(out, res, stamp=datetime.now().strftime("%Y-%m-%d %H:%M"))
    logfn("Extensión Pérdida Esperada: %s | total inundación=%s | empresas=%d | sin S/=%d | ICEN=%s"
          % (out, round(res["resumen"]["total_perdida_esperada"]), res["resumen"]["n_empresas"],
             len(res["resumen"]["empresas_sin_dato_S"]), enso.get("icen")))
    return out
