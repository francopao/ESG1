def construir_html_companion(out_path, resultado, stamp=None):
    payload = {"filas": resultado["filas"], "indirecto": resultado["indirecto"],
               "resumen": resultado["resumen"],
               "stamp": stamp or datetime.now().strftime("%Y-%m-%d %H:%M")}
    html = _TPL.replace("__PAYLOAD__", json.dumps(payload, ensure_ascii=False))
    with open(out_path, "w", encoding="utf-8") as f:
        f.write(html)
    return out_path


