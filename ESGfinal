                elif j == 6:                                 # Países
                    c.alignment = A_L
                else:
                    c.alignment = A_L if j in (1, 2) else (A_R if j in (3, 4) else A_C)
                if j == 3:                                   # AUM Total
                    c.number_format = FMT_S
                elif j == 4:                                 # AUM sin ponderar
                    c.number_format = FMT_S
                elif j == 5:                                 # % ponderación
                    c.number_format = FMT_P
                elif 7 <= j <= 16:                           # bloques % / monto por nivel
