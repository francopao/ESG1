# ==============================================================================
# 11) FEN APOYO — MAPA DEPARTAMENTAL + TABLA INTERACTIVA
# ==============================================================================
# Módulo 100% ADITIVO. No altera nada existente.
# Carga la hoja "FEN_Apoyo" del mismo archivo de Riesgos Físicos,
# genera un HTML independiente con:
#   A) Mapa coroplético departamental (Plotly choropleth) coloreado por categoría FEN
#      con paleta propia AFP Integra (no copia la imagen de Apoyo Consultoría).
#   B) Tabla interactiva de doble entrada:
#      - Filas (index): los 5 niveles CENEPRED (1-5), encabezado "Riesgo"
#      - Columnas: categorías únicas de la columna B de FEN_Apoyo
#      - Valores: % AUM de activos físicos en esa celda / AUM total del header
#      - Selector de activos (misma lógica que chart 2: sector + clase)
#   Ambos comparten un selector que filtra por sector/clase, idéntico al chart 2.
# ==============================================================================

FEN_APOYO_SHEET_HINTS = ["FEN_Apoyo", "FEN Apoyo", "FEN", "Apoyo"]

# Paleta para las categorías FEN — colores AFP Integra personalizados
# (distintos al rojo/gris/azul de la imagen de Apoyo para no ser copia)
FEN_CAT_COLORS = {
    "Lluvias":                {"fill": "#00AECB", "text": "#fff"},   # cyan AFP
    "Temperaturas y Lluvias": {"fill": "#1E2E6E", "text": "#fff"},   # azul AFP
    "Sequías":                {"fill": "#E3E829", "text": "#1E2E6E"}, # amarillo AFP
    "Sin Impacto":            {"fill": "#DCDDDE", "text": "#7E8083"}, # gris AFP
}
FEN_CAT_DEFAULT = {"fill": "#7E8083", "text": "#fff"}

# Normalización robusta de nombre de departamento (para cruzar con geojson)
def _norm_dep(s):
    import unicodedata
    if s is None:
        return ""
    s = str(s).strip().upper()
    s = "".join(c for c in unicodedata.normalize("NFKD", s) if not unicodedata.combining(c))
    return s


def load_fen_apoyo(risk_path):
    """Lee la hoja FEN_Apoyo del archivo de Riesgos Físicos.
    Devuelve:
      - fen_dep: {NOMBDEP_normalizado: categoria_string}  (columna B)
      - categorias: lista ordenada de categorías únicas (columna B)
      - region_dep: {NOMBDEP_normalizado: region_string}  (columna C / 3ra columna)
    """
    import openpyxl
    wb = openpyxl.load_workbook(risk_path, read_only=True, data_only=True)
    hoja = None
    for h in FEN_APOYO_SHEET_HINTS:
        for s in wb.sheetnames:
            if norm(h) in norm(s):
                hoja = s
                break
        if hoja:
            break
    if hoja is None:
        log(f"[FEN_Apoyo] No se encontró la hoja FEN_Apoyo en {os.path.basename(risk_path)}. "
            f"Hojas disponibles: {wb.sheetnames}. Se omite el chart FEN.", "WARN")
        wb.close()
        return {}, [], {}
    ws = wb[hoja]
    fen_dep = {}
    region_dep = {}      # {NOMBDEP_normalizado: region (3ra columna)}
    cat_order = []
    for row in ws.iter_rows(min_row=2, max_col=3, values_only=True):
        dep, cat = row[0], row[1]
        reg = row[2] if len(row) > 2 else None
        if dep is None:
            continue
        dep_n = _norm_dep(dep)
        cat_s = str(cat).strip() if cat is not None else "Sin Impacto"
        fen_dep[dep_n] = cat_s
        if reg is not None and str(reg).strip():
            region_dep[dep_n] = str(reg).strip()
        if cat_s not in cat_order:
            cat_order.append(cat_s)
    wb.close()
    log(f"[FEN_Apoyo] {len(fen_dep)} departamentos cargados, "
        f"categorías: {cat_order}, regiones: {sorted(set(region_dep.values()))}.")
    return fen_dep, cat_order, region_dep


def build_fen_table_data(districts, fen_dep, categorias, exp_clase):
    """Construye la tabla de doble entrada para el payload JS.
    Retorna:
      tabla_data: {categoria: {nivel_cenepred: {aum, aum_total_cat}}}
      donde aum_total_cat = AUM total de activos físicos de esa categoría FEN.
    Para cada celda: % = aum / aum_total_cat * 100
    """
    # aum[cat][nivel] = suma de exposición de activos en ese cat+nivel
    # aum_cat[cat] = total de esa categoría (denominador de columna)
    from collections import defaultdict
    aum = defaultdict(lambda: defaultdict(float))
    aum_cat = defaultdict(float)

    for d in districts:
        dep_n = _norm_dep(d.get("dep", ""))
        cat = fen_dep.get(dep_n)
        if cat is None:
            continue  # departamento no en FEN_Apoyo (no debería pasar)
        nivel = d.get("nivel")  # nivel CENEPRED global (max o comb según config)
        # Usar todos los aportes sin filtro de clase (la tabla usa el total)
        exp_dist = sum(a.get("monto", 0) or 0 for a in d.get("aportes", []))
        if exp_dist <= 0:
            continue
        lv = nivel if nivel in [1, 2, 3, 4, 5] else None
        if lv is None:
            continue
        aum[cat][lv] += exp_dist
        aum_cat[cat] += exp_dist

    # Armar estructura para el payload
    tabla = {}
    for cat in categorias:
        tabla[cat] = {}
        denom = aum_cat.get(cat, 0)
        for lv in [1, 2, 3, 4, 5]:
            v = aum[cat].get(lv, 0)
            tabla[cat][str(lv)] = {
                "aum": round(v, 2),
                "aum_cat": round(denom, 2),
                "pct": round(v / denom * 100, 1) if denom > 0 else 0.0,
            }
    return tabla


def export_html_fen(out_path, geojson_dep, districts, fen_dep, categorias,
                    exp_clase, aum_cartera, emp_sector, tabla_fen,
                    geojson_distrital, scores, region_dep=None):
    """Genera el HTML independiente del chart FEN."""
    # Construir lookup dep -> ubigeos (para el mapa de activos)
    dep_ubigeos = {}
    for f in geojson_distrital.get("features", []):
        dep = f["properties"].get("NOMBDEP", "")
        u = str(f["properties"].get("IDDIST", "")).split(".")[0].zfill(6)
        dep_ubigeos.setdefault(dep, []).append(u)

    # payload
    fen_cat_colors = {
        cat: FEN_CAT_COLORS.get(cat, FEN_CAT_DEFAULT)
        for cat in categorias
    }
    payload = {
        "generado": datetime.now().strftime("%Y-%m-%d %H:%M"),
        "fen_dep": fen_dep,           # {dep_normalizado: categoria}
        "region_dep": region_dep or {},  # {dep_normalizado: region (3ra col FEN_Apoyo)}
        "categorias": categorias,     # orden de columnas
        "fen_cat_colors": fen_cat_colors,
        "tabla_fen": tabla_fen,       # {cat: {nivel_str: {aum,aum_cat,pct}}}
        "districts": [
            {
                "u": d.get("ubigeo"), "dep": d.get("dep"),
                "prov": d.get("prov"), "dist": d.get("dist"),
                "smm": d.get("score_mm"), "sinu": d.get("score_inu"),
                "sseq": d.get("score_seq"),
                "nivel": d.get("nivel"),
                "ap": [
                    {"e": a.get("emisor"), "s": a.get("sector"),
                     "m": round(float(a.get("monto", 0)), 2),
                     "ac": list(a.get("activos", []) or [])}
                    for a in d.get("aportes", [])
                    if (a.get("monto", 0) or 0) > 0
                ],
            }
            for d in districts
        ],
        "exp_clase": exp_clase or {},
        "aum_cartera": aum_cartera or {"TODOS": 0, "RENTA VARIABLE": 0, "RENTA FIJA": 0},
        "emp_sector": emp_sector or {},
        "dep_ubigeos": dep_ubigeos,
        "geojson_dep": geojson_dep,
        "afp": {"azul": AFP_AZUL, "cyan": AFP_CYAN, "amar": AFP_AMAR,
                "gris": AFP_GRIS, "plomo": AFP_PLOMO},
    }

    html = _FEN_HTML_TEMPLATE.replace(
        "__PAYLOAD__", json.dumps(payload, ensure_ascii=False))
    os.makedirs(os.path.dirname(out_path), exist_ok=True)
    with open(out_path, "w", encoding="utf-8") as f:
        f.write(html)
    log(f"[FEN_Apoyo] HTML generado: {out_path}")
    return out_path


