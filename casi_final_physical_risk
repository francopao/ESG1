NIVELES_ALTOS = [5, 4, 3]

# Tipo de cambio por defecto si no se logra leer la hoja "Tipo de Cambio".
FX_DEFAULT = 3.5

# Mapeo sector -> tipo de ícono en el mapa.
#   Minería -> mina ; Financiero -> banco ; el resto -> círculo.
SECTOR_ICONO = {
    "Minería": "mina",
    "Financiero": "banco",
}
