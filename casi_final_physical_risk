def _trim_districts(districts):
    """Reduce 'districts' a lo estrictamente necesario para este dashboard:
    ubigeo, geografía, los TRES scores por peligro y los aportes (emisor, sector,
    monto, activos)."""
    out = []
    for d in districts:
        ap = []
        for a in d.get("aportes", []):
            if a.get("monto", 0) <= 0:
                continue
            ap.append({
                "e": a.get("emisor"),
                "s": a.get("sector"),
                "m": round(float(a.get("monto", 0.0)), 2),
                "ac": list(a.get("activos", []) or []),
            })
        out.append({
            "u": d.get("ubigeo"),
            "dep": d.get("dep"), "prov": d.get("prov"), "dist": d.get("dist"),
            "smm": d.get("score_mm"), "sinu": d.get("score_inu"),
            "sseq": d.get("score_seq"),
            "ap": ap,
        })
    return out


def _sector_icono(sector):
    return SECTOR_ICONO.get(sector, "circulo")


def leer_mitigantes(path, logfn=print):
    """Lee la hoja del semestre actual del archivo Mitigantes.xlsx. Detecta el sheet
    segun el mes (<=6 -> 1S, >6 -> 2S) y arma 'XSyy' (ej '1S26'); si no existe usa el
    semestre anterior. Devuelve {empresa: 'Bajo'|'Medio'|'Alto'} a partir del valor
    numerico 1/2/3 (data_only resuelve formulas; valor directo se trata igual)."""
    MAPA_LABEL = {1: 'Bajo', 2: 'Medio', 3: 'Alto'}
    resultado = {}
    if not path or not os.path.exists(path):
        logfn(f"[Activos] Mitigantes: archivo no encontrado ({path}). Se usara '-'.")
        return resultado
    try:
        import openpyxl
        from datetime import datetime
        hoy = datetime.now()
        anio2 = str(hoy.year)[-2:]
        sem = '1' if hoy.month <= 6 else '2'
        candidatos = [f"{sem}S{anio2}"]
        if sem == '1':
            candidatos.append(f"2S{str(hoy.year - 1)[-2:]}")
        else:
            candidatos.append(f"1S{anio2}")
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        hoja_usar = None
        for c in candidatos:
            if c in wb.sheetnames:
                hoja_usar = c
                break
        if hoja_usar is None:
            logfn(f"[Activos] Mitigantes: no se encontro hoja para {candidatos}. "
                  f"Hojas disponibles: {wb.sheetnames}")
            wb.close()
            return resultado
        ws = wb[hoja_usar]
        logfn(f"[Activos] Mitigantes: usando hoja '{hoja_usar}'.")
        for row in ws.iter_rows(min_row=2, max_col=2, values_only=True):
            empresa, val = (row[0], row[1]) if len(row) >= 2 else (None, None)
            if not empresa:
                continue
            try:
                num = int(round(float(val)))
                label = MAPA_LABEL.get(num, '\u2014')
            except (TypeError, ValueError):
                label = '\u2014'
            resultado[str(empresa).strip()] = label
        wb.close()
    except Exception as e:
        logfn(f"[Activos] Error leyendo Mitigantes ({e}). Se usara '-'.")
    return resultado


def _color_nino(enfen):
    """Color/opacidad/etiqueta del rectángulo Región Niño 1+2 según el ÚLTIMO
    registro ENFEN cuyo estado no sea 'NO ACTIVO' / 'NO IDENTIFICADO'. Recibe la
    lista ENFEN ([{fecha, estado, conf}, ...]) ya parseada (mismo formato que usa
    el script padre). Devuelve un dict con las claves requeridas
    {color, opacity, label} y, de forma aditiva, el {estado, fecha} del registro
    usado (para el tooltip de hover en el mapa)."""
    neutro = {"color": "#aaaaaa", "opacity": 0.25, "label": "Condiciones Neutras",
              "estado": None, "fecha": None}
    if not enfen:
        return neutro

    def _sin_acentos(s):
        import unicodedata
        return "".join(c for c in unicodedata.normalize("NFD", _norm_txt(s))
                       if unicodedata.category(c) != "Mn")

    usado = None
    for rec in reversed(enfen):
        est = _sin_acentos(rec.get("estado"))
        if not est:
            continue
        if "NO ACTIVO" in est or "NO IDENTIFICADO" in est:
            continue
        usado = rec
        break
    if usado is None:
        return neutro
    est = _sin_acentos(usado.get("estado"))
    base = {"estado": usado.get("estado"), "fecha": usado.get("fecha")}
    if any(k in est for k in ("FUERTE", "MUY FUERTE", "EXTRAORDINARIO")):
        # 'MUY FUERTE' contiene 'FUERTE'; cualquiera de los tres -> rojo
        return {"color": "#dc2626", "opacity": 0.65, "label": "El Niño Fuerte", **base}
    if "MODERADO" in est:
        return {"color": "#F97316", "opacity": 0.55, "label": "El Niño Moderado", **base}
    if "DEBIL" in est:
        return {"color": "#facc15", "opacity": 0.45, "label": "El Niño Débil", **base}
    return {"color": "#aaaaaa", "opacity": 0.25, "label": "Condiciones Neutras", **base}


def _color_itcp(serie_itcp):
    """Color/opacidad/etiqueta del rectangulo Nino 1+2 segun el ULTIMO valor ITCP
    (temperatura superficial del mar costero). Opacidades deliberadamente bajas: el
    rectangulo es contextual, el protagonista es el coropletico distrital."""
    if not serie_itcp:
        return {"color": "#aaaaaa", "opacity": 0.15,
                "label": "Sin datos ITCP", "valor": None, "fecha": None}
    ultimo = serie_itcp[-1]
    v = ultimo.get("v")
    f = ultimo.get("f")
    if v is None:
        return {"color": "#aaaaaa", "opacity": 0.15,
                "label": "Sin datos ITCP", "valor": None, "fecha": f}
    if v >= 1.4:
        cat = {"color": "#dc2626", "opacity": 0.45, "label": "El Nino Fuerte (ITCP)"}
    elif v >= 1.0:
        cat = {"color": "#F97316", "opacity": 0.38, "label": "El Nino Moderado (ITCP)"}
    elif v >= 0.4:
        cat = {"color": "#facc15", "opacity": 0.30, "label": "El Nino Debil (ITCP)"}
    elif v <= -1.4:
        cat = {"color": "#2471a3", "opacity": 0.38, "label": "La Nina Fuerte (ITCP)"}
    elif v <= -1.0:
        cat = {"color": "#5dade2", "opacity": 0.30, "label": "La Nina Moderada (ITCP)"}
    elif v <= -0.5:
        cat = {"color": "#85c1e9", "opacity": 0.22, "label": "La Nina Debil (ITCP)"}
    else:
        cat = {"color": "#aaaaaa", "opacity": 0.15, "label": "Condiciones Neutras (ITCP)"}
    return {**cat, "valor": round(v, 3), "fecha": f}


def generar_dashboard_activos(out_dir, districts, exp_clase, aum_cartera,
                              emp_sector, risk_path, geojson,
                              enfen=None, mitigantes_path=None,
                              clima_itcp=None,
                              stamp=None, logfn=print):
    """Punto de entrada público (espejo de rf_extension.generar_extension)."""
    if stamp is None:
        stamp = datetime.now().strftime("%Y%m%d_%H%M")

    fx = leer_tipo_cambio(risk_path, logfn=logfn)
    mitigantes = leer_mitigantes(mitigantes_path, logfn=logfn)
    centroids, bbox_dist, bbox_prov, bbox_dep = calcular_geometria(geojson)

    # sectores presentes -> icono/color
    sectores = sorted({a.get("sector") for d in districts
                       for a in d.get("aportes", []) if a.get("sector")})
    sector_icono = {s: _sector_icono(s) for s in sectores}
    sector_color = {s: SECTOR_COLOR.get(s, SECTOR_COLOR_DEFAULT) for s in sectores}

    # CAMBIO 1: denominador mapeado = AUM solo de emisores con >=1 distrito con
    # monto>0 en districts (excluye soberanos/fondos sin activo físico). Así las
    # filas 1+2+...+5+N/D de cada peligro suman exactamente 100%.
    exp_clase = exp_clase or {}
    emisores_mapeados = {a["emisor"] for d in districts
                         for a in d.get("aportes", [])
                         if a.get("monto", 0) > 0 and a.get("emisor")}
    aum_mapeado = {
        "TODOS": sum(exp_clase[e].get("TOTAL", 0)
                     for e in emisores_mapeados if e in exp_clase),
        "RENTA VARIABLE": sum(exp_clase[e].get("RENTA VARIABLE", 0)
                              for e in emisores_mapeados if e in exp_clase),
        "RENTA FIJA": sum(exp_clase[e].get("RENTA FIJA", 0)
                          for e in emisores_mapeados if e in exp_clase),
    }

    payload = {
        "generado": datetime.now().strftime("%Y-%m-%d %H:%M"),
        "districts": _trim_districts(districts),
        "exp_clase": exp_clase or {},
        "aum_cartera": aum_cartera or {"TODOS": 0, "RENTA VARIABLE": 0, "RENTA FIJA": 0},
        "aum_mapeado": aum_mapeado,
        "emp_sector": emp_sector or {},
        "niveles_altos": NIVELES_ALTOS,
        "fx": fx,
        "centroids": centroids,
        "bbox_dist": bbox_dist,
        "bbox_prov": bbox_prov,
        "bbox_dep": bbox_dep,
        "sector_icono": sector_icono,
        "sector_color": sector_color,
        "nino": _color_nino(enfen),
        "itcp": _color_itcp(clima_itcp),
        "geojson_dep": DEP_GEOJSON_MIN,
        "dep_ubigeos": {
            dep: [str(f["properties"].get("IDDIST", "")).split(".")[0].zfill(6)
                  for f in geojson["features"]
                  if f["properties"].get("NOMBDEP") == dep]
            for dep in {f["properties"].get("NOMBDEP", "")
                        for f in geojson["features"]} if dep
        },
        "mitigantes": mitigantes,
        "afp": {"azul": AFP_AZUL, "cyan": AFP_CYAN, "amar": AFP_AMAR,
                "gris": AFP_GRIS, "plomo": AFP_PLOMO},
    }

    # GeoJSON minimal (solo lo necesario para pintar y navegar).
    geojson_min = {"type": "FeatureCollection", "features": [
        {"type": "Feature",
         "properties": {
             "IDDIST": str(f["properties"].get("IDDIST", "")).split(".")[0].zfill(6),
             "NOMBDIST": f["properties"].get("NOMBDIST"),
             "NOMBPROV": f["properties"].get("NOMBPROV"),
             "NOMBDEP": f["properties"].get("NOMBDEP")},
         "geometry": f["geometry"]}
        for f in geojson["features"] if f.get("geometry")]}

    html = _HTML_TEMPLATE.replace("__PAYLOAD__", json.dumps(payload, ensure_ascii=False))
    html = html.replace("__GEOJSON__", json.dumps(geojson_min, ensure_ascii=False))

    os.makedirs(out_dir, exist_ok=True)
    out_path = os.path.join(out_dir, f"Dashboard_Activos_Riesgo_{stamp}.html")
    with open(out_path, "w", encoding="utf-8") as fh:
        fh.write(html)
    logfn(f"[Activos] HTML generado: {out_path}")

    # Excel histórico de Riesgos Climáticos (no afecta al HTML si falla)
    try:
        periodo = _periodo_actual(mitigantes_path)
        generar_excel_riesgos(out_dir, districts, exp_clase, emp_sector,
                              mitigantes, periodo, fx, stamp, logfn=logfn)
    except Exception as e:
        logfn(f"[Activos] No se pudo generar el Excel de riesgos: {e}")

    return out_path


def _periodo_actual(mitigantes_path=None):
    """Etiqueta de semestre ('1S26', '2S25', ...). Si hay archivo de mitigantes usa
    la hoja de semestre encontrada; si no, la calcula de la fecha."""
    from datetime import datetime
    hoy = datetime.now()
    anio2 = str(hoy.year)[-2:]
    sem = '1' if hoy.month <= 6 else '2'
    candidatos = [f"{sem}S{anio2}",
                  (f"2S{str(hoy.year - 1)[-2:]}" if sem == '1' else f"1S{anio2}")]
    if mitigantes_path and os.path.exists(mitigantes_path):
        try:
            import openpyxl
            wb = openpyxl.load_workbook(mitigantes_path, read_only=True)
            hojas = wb.sheetnames
            wb.close()
            for c in candidatos:
                if c in hojas:
                    return c
        except Exception:
            pass
    return candidatos[0]


def _mit_lookup(emisor, mitigantes):
    """Busca el mitigante de un emisor tolerando tildes/mayusculas."""
    if emisor in mitigantes:
        return mitigantes[emisor]
    import unicodedata

    def nrm(s):
        return "".join(c for c in unicodedata.normalize("NFD", str(s))
                       if unicodedata.category(c) != "Mn").lower().strip()
    ne = nrm(emisor)
    for k, v in mitigantes.items():
        if nrm(k) == ne:
            return v
    return "\u2014"


def _calc_scores_py(districts):
    """Score CENEPRED por emisor y peligro, ponderado por la plata del emisor en
    cada distrito (cartera total). Distritos sin score cuentan 0 (denominador =
    plata total del emisor). Misma logica que calcScores() del dashboard."""
    tot, perd = {}, {}
    for d in districts:
        acc = {}
        for a in d.get("aportes", []):
            m = a.get("monto", 0) or 0
            if m > 0:
                acc[a["emisor"]] = acc.get(a["emisor"], 0) + m
        for e, m in acc.items():
            tot[e] = tot.get(e, 0) + m
            perd.setdefault(e, []).append(
                (d.get("score_mm"), d.get("score_inu"), d.get("score_seq"), m))
    out = {}
    for e, T in tot.items():
        amm = ainu = aseq = 0.0
        for mm, inu, seq, m in perd[e]:
            f = (m / T) if T else 0
            amm += f * (mm if isinstance(mm, (int, float)) else 0)
            ainu += f * (inu if isinstance(inu, (int, float)) else 0)
            aseq += f * (seq if isinstance(seq, (int, float)) else 0)
        g = (amm + ainu + aseq) / 3
        out[e] = {"mm": round(amm, 2), "inu": round(ainu, 2),
                  "seq": round(aseq, 2), "global": round(g, 2)}
    return out


def generar_excel_riesgos(out_dir, districts, exp_clase, emp_sector, mitigantes,
                          periodo, fx, stamp=None, logfn=print):
    """Genera 'Riesgos Climáticos - <periodo>.xlsx' con hojas: Resumen, Activos por
    Empresa, Activos N-D, Score por Empresa, Score por Sector y Mitigantes. Data
    estructurada semestral para construir historia."""
    from openpyxl import Workbook
    from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
    from openpyxl.utils import get_column_letter
    from datetime import datetime

    AZUL = "1E2E6E"; GRISBG = "F1F3F8"
    F_TIT = Font(name="Calibri", size=14, bold=True, color=AZUL)
    F_SUB = Font(name="Calibri", size=10, color="7E8083")
    F_HEAD = Font(name="Calibri", size=10, bold=True, color="FFFFFF")
    F_BODY = Font(name="Calibri", size=10, color="1F2533")
    F_BOLD = Font(name="Calibri", size=10, bold=True, color="1F2533")
    FILL_HEAD = PatternFill("solid", fgColor=AZUL)
    THIN = Side(style="thin", color="DCDDDE")
    BORDER = Border(left=THIN, right=THIN, top=THIN, bottom=THIN)
    A_L = Alignment(horizontal="left", vertical="center")
    A_C = Alignment(horizontal="center", vertical="center")
    A_R = Alignment(horizontal="right", vertical="center")
    FMT_S = '#,##0;(#,##0);-'
    FMT_SC = '0.00'

    def fill_score(v):
        if v < 2:  return PatternFill("solid", fgColor="D4EDDA")
        if v < 3:  return PatternFill("solid", fgColor="FFF3CD")
        if v <= 4: return PatternFill("solid", fgColor="FFE0B2")
        return PatternFill("solid", fgColor="F8D7DA")

    def fill_mit(v):
        return {"Bajo": PatternFill("solid", fgColor="D4EDDA"),
                "Medio": PatternFill("solid", fgColor="FFF3CD"),
                "Alto": PatternFill("solid", fgColor="F8D7DA")}.get(v)

    def header_row(ws, row, cols, widths=None):
        for j, txt in enumerate(cols, start=1):
            c = ws.cell(row=row, column=j, value=txt)
            c.font = F_HEAD; c.fill = FILL_HEAD; c.alignment = A_C; c.border = BORDER
        if widths:
            for j, w in enumerate(widths, start=1):
                ws.column_dimensions[get_column_letter(j)].width = w

    fxv = (fx or {}).get("valor", 3.5)

    scores = _calc_scores_py(districts)
    activos = []
    aum_emp = {}
    for e in scores:
        aum_emp[e] = (exp_clase.get(e, {}) or {}).get("TOTAL", 0)
    for d in districts:
        for a in d.get("aportes", []):
            m = a.get("monto", 0) or 0
            if m <= 0:
                continue
            acts = a.get("activos") or ["(activo s/d)"]
            cuota = m / len(acts)
            for nom in acts:
                activos.append({
                    "emisor": a["emisor"],
                    "sector": a.get("sector") or emp_sector.get(a["emisor"], ""),
                    "activo": nom, "ubigeo": d.get("ubigeo"),
                    "dep": d.get("dep"), "prov": d.get("prov"),
                    "dist": d.get("dist"), "plata": cuota,
                    "mm": d.get("score_mm"), "inu": d.get("score_inu"),
                    "seq": d.get("score_seq")})

    wb = Workbook()
    emisores = sorted(scores.keys())
    sectores = sorted({s for s in emp_sector.values() if s})

    # ---- HOJA 1: RESUMEN ----
    ws = wb.active; ws.title = "Resumen"; ws.sheet_view.showGridLines = False
    ws["A1"] = "Riesgos Climáticos - Activos Físicos y Riesgo CENEPRED"; ws["A1"].font = F_TIT
    ws["A2"] = (f"Periodo {periodo} - Generado {datetime.now().strftime('%Y-%m-%d %H:%M')}"
                f" - TC USD {fxv}"); ws["A2"].font = F_SUB
    n_act = len(activos)
    n_nd = sum(1 for x in activos if not all(isinstance(x[k], (int, float))
               for k in ("mm", "inu", "seq")))
    aum_total = sum(aum_emp.values())
    r = 4
    for nombre, val, fmt in [("AUM total mapeado (S/)", aum_total, FMT_S),
                             ("Empresas mapeadas", len(emisores), '#,##0'),
                             ("Activos físicos", n_act, '#,##0'),
                             ("Activos con peligro N/D", n_nd, '#,##0')]:
        ws.cell(row=r, column=1, value=nombre).font = F_BOLD
        c = ws.cell(row=r, column=2, value=val); c.font = F_BODY
        c.number_format = fmt; c.alignment = A_R
        r += 1
    ws.column_dimensions["A"].width = 34; ws.column_dimensions["B"].width = 18
    r += 1
    ws.cell(row=r, column=1, value="Resumen por sector").font = F_TIT; r += 1
    header_row(ws, r, ["Sector", "Empresas", "Activos", "AUM total (S/)", "Score Global (pond.)"])
    r += 1
    for sec in sectores:
        emps = [e for e in emisores if emp_sector.get(e) == sec]
        if not emps:
            continue
        nact = sum(1 for x in activos if x["sector"] == sec)
        aum_s = sum(aum_emp[e] for e in emps)
        gp = (sum(scores[e]["global"] * aum_emp[e] for e in emps) / aum_s) if aum_s else 0
        for j, v in enumerate([sec, len(emps), nact, aum_s, round(gp, 2)], start=1):
            c = ws.cell(row=r, column=j, value=v); c.font = F_BODY; c.border = BORDER
            c.alignment = A_L if j == 1 else (A_R if j == 4 else A_C)
            if j == 4: c.number_format = FMT_S
            if j == 5: c.number_format = FMT_SC; c.fill = fill_score(round(gp, 2))
        r += 1
    for j, w in enumerate([26, 12, 10, 18, 20], start=1):
        ws.column_dimensions[get_column_letter(j)].width = w
    ws.freeze_panes = "A4"

    # ---- HOJA 2: ACTIVOS POR EMPRESA ----
    ws = wb.create_sheet("Activos por Empresa"); ws.sheet_view.showGridLines = False
    header_row(ws, 1, ["Empresa", "Sector", "AUM Total Empresa (S/)", "Activo Físico",
                       "Departamento", "Provincia", "Distrito", "Score MM",
                       "Score Inund.", "Score Sequía", "Plata del Activo (S/)"],
               [26, 16, 20, 30, 16, 18, 18, 10, 11, 11, 18])
    r = 2
    for x in sorted(activos, key=lambda z: (z["emisor"], -z["plata"])):
        fila = [x["emisor"], x["sector"], aum_emp.get(x["emisor"], 0), x["activo"],
                x["dep"], x["prov"], x["dist"],
                x["mm"] if isinstance(x["mm"], (int, float)) else "N/D",
                x["inu"] if isinstance(x["inu"], (int, float)) else "N/D",
                x["seq"] if isinstance(x["seq"], (int, float)) else "N/D",
                round(x["plata"], 2)]
        for j, v in enumerate(fila, start=1):
            c = ws.cell(row=r, column=j, value=v); c.font = F_BODY; c.border = BORDER
            c.alignment = A_L if j in (1, 2, 4, 5, 6, 7) else (A_R if j in (3, 11) else A_C)
            if j in (3, 11): c.number_format = FMT_S
        r += 1
    ws.freeze_panes = "A2"
    if r > 2: ws.auto_filter.ref = f"A1:K{r-1}"

    # ---- HOJA 3: ACTIVOS N-D ----
    ws = wb.create_sheet("Activos N-D"); ws.sheet_view.showGridLines = False
    ws["A1"] = ("Activos físicos en distritos SIN score CENEPRED valido para el peligro "
                "indicado (catalogados 'N/D' en el dashboard)."); ws["A1"].font = F_SUB
    header_row(ws, 2, ["Empresa", "Sector", "Activo Físico", "Ubigeo", "Departamento",
                       "Provincia", "Distrito", "Peligro sin score",
                       "Plata del Activo (S/)", "% del AUM de la empresa"],
               [26, 16, 30, 10, 16, 18, 18, 18, 18, 20])
    HZP = [("mm", "Movimientos de Masa"), ("inu", "Inundación"), ("seq", "Sequías Severas")]
    r = 3
    for x in sorted(activos, key=lambda z: (z["emisor"], -z["plata"])):
        for key, etiqueta in HZP:
            if not isinstance(x[key], (int, float)):
                aum_e = aum_emp.get(x["emisor"], 0) or 0
                pct = (x["plata"] / aum_e) if aum_e else 0
                fila = [x["emisor"], x["sector"], x["activo"], x["ubigeo"], x["dep"],
                        x["prov"], x["dist"], etiqueta, round(x["plata"], 2), pct]
                for j, v in enumerate(fila, start=1):
                    c = ws.cell(row=r, column=j, value=v); c.font = F_BODY; c.border = BORDER
                    c.alignment = A_L if j in (1, 2, 3, 5, 6, 7) else (A_R if j in (9, 10) else A_C)
                    if j == 9: c.number_format = FMT_S
                    if j == 10: c.number_format = '0.00%'
                r += 1
    ws.freeze_panes = "A3"
    if r > 3: ws.auto_filter.ref = f"A2:J{r-1}"

    # ---- HOJA 4: SCORE POR EMPRESA ----
    ws = wb.create_sheet("Score por Empresa"); ws.sheet_view.showGridLines = False
    ws["A1"] = "Detalle del Score CENEPRED por empresa (ponderado por AUM distrital)"
    ws["A1"].font = F_TIT
    ws["A2"] = ("Score por peligro = suma( plata del emisor en el distrito / plata total "
                "del emisor x score CENEPRED del distrito ). Score Global = promedio de los "
                "tres peligros. Mitigante: nivel del periodo (archivo Mitigantes).")
    ws["A2"].font = F_SUB
    header_row(ws, 4, ["Empresa", "Sector", "AUM Total (S/)", "Score MM", "Score Inund.",
                       "Score Sequía", "Score Global", "Mitigante (" + str(periodo) + ")"],
               [26, 16, 18, 11, 12, 12, 13, 18])
    r = 5
    for e in sorted(emisores, key=lambda z: -scores[z]["global"]):
        s = scores[e]; mit = _mit_lookup(e, mitigantes)
        fila = [e, emp_sector.get(e, ""), aum_emp.get(e, 0),
                s["mm"], s["inu"], s["seq"], s["global"], mit]
        for j, v in enumerate(fila, start=1):
            c = ws.cell(row=r, column=j, value=v); c.font = F_BODY; c.border = BORDER
            c.alignment = A_L if j in (1, 2) else (A_R if j == 3 else A_C)
            if j == 3: c.number_format = FMT_S
            if j in (4, 5, 6, 7): c.number_format = FMT_SC; c.fill = fill_score(v)
            if j == 8 and fill_mit(v): c.fill = fill_mit(v)
        r += 1
    ws.freeze_panes = "A5"
    if r > 5: ws.auto_filter.ref = f"A4:H{r-1}"

    # ---- HOJA 5: SCORE POR SECTOR ----
    ws = wb.create_sheet("Score por Sector"); ws.sheet_view.showGridLines = False
    ws["A1"] = "Score CENEPRED por sector (agregado, ponderado por AUM)"; ws["A1"].font = F_TIT
    header_row(ws, 3, ["Sector", "Empresas", "AUM Total (S/)", "Score MM", "Score Inund.",
                       "Score Sequía", "Score Global"], [26, 12, 18, 11, 12, 12, 13])
    r = 4
    sec_rows = []
    for sec in sectores:
        emps = [e for e in emisores if emp_sector.get(e) == sec]
        if not emps:
            continue
        aum_s = sum(aum_emp[e] for e in emps) or 1
        agg = {k: round(sum(scores[e][k] * aum_emp[e] for e in emps) / aum_s, 2)
               for k in ("mm", "inu", "seq", "global")}
        sec_rows.append((sec, len(emps), sum(aum_emp[e] for e in emps), agg))
    for sec, nemp, aum_s, agg in sorted(sec_rows, key=lambda z: -z[3]["global"]):
        fila = [sec, nemp, aum_s, agg["mm"], agg["inu"], agg["seq"], agg["global"]]
        for j, v in enumerate(fila, start=1):
            c = ws.cell(row=r, column=j, value=v); c.font = F_BODY; c.border = BORDER
            c.alignment = A_L if j == 1 else (A_R if j == 3 else A_C)
            if j == 3: c.number_format = FMT_S
            if j in (4, 5, 6, 7): c.number_format = FMT_SC; c.fill = fill_score(v)
        r += 1
    ws.freeze_panes = "A4"

    # ---- HOJA 6: MITIGANTES ----
    ws = wb.create_sheet("Mitigantes"); ws.sheet_view.showGridLines = False
    ws["A1"] = f"Mitigantes considerados - periodo {periodo}"; ws["A1"].font = F_TIT
    ws["A2"] = "Fuente: archivo Mitigantes (1=Bajo, 2=Medio, 3=Alto)."; ws["A2"].font = F_SUB
    header_row(ws, 4, ["Empresa", "Mitigante", "Periodo"], [30, 16, 12])
    r = 5
    if mitigantes:
        for emp, val in sorted(mitigantes.items()):
            for j, v in enumerate([emp, val, periodo], start=1):
                c = ws.cell(row=r, column=j, value=v); c.font = F_BODY; c.border = BORDER
                c.alignment = A_L if j == 1 else A_C
                if j == 2 and fill_mit(v): c.fill = fill_mit(v)
            r += 1
    else:
        ws.cell(row=5, column=1, value="(No se cargó archivo de mitigantes)").font = F_SUB
    ws.freeze_panes = "A5"

    os.makedirs(out_dir, exist_ok=True)
    out_path = os.path.join(out_dir, f"Riesgos Climáticos - {periodo}.xlsx")
    wb.save(out_path)
    logfn(f"[Activos] Excel generado: {out_path}")
    return out_path


