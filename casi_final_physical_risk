<script>
const P = __PAYLOAD__;
const AFP = P.afp;
const FEN_DEP = P.fen_dep;           // {dep_norm: categoria}
const CATS = P.categorias;            // orden de columnas
const CAT_COL = P.fen_cat_colors;    // {cat: {fill,text}}
const TABLA_ORIG = P.tabla_fen;      // {cat: {nivel: {aum,aum_cat,pct}}}
const D = P.districts;
const EXP_CLASE = P.exp_clase || {};
const AUM = P.aum_cartera || {TODOS:0,'RENTA VARIABLE':0,'RENTA FIJA':0};
const EMP_SEC = P.emp_sector || {};
const REGION_DEP = P.region_dep || {};   // {dep_norm: region (3ra col FEN_Apoyo)}
const GEO_DEP = P.geojson_dep;
const DEP_UBI = P.dep_ubigeos || {};

document.getElementById('gen').textContent = P.generado;
document.getElementById('footgen').textContent = P.generado;

// Indexar distritos
const byU = {}; D.forEach(d => byU[d.u] = d);

// ---- Estado global ----
let TAB = 'resumen';
let SOLO_ACTIVOS = false;
const classKey = () => TAB==='rv'?'RENTA VARIABLE': TAB==='rf'?'RENTA FIJA':'TODOS';

function classFrac(emisor){
  const ck = classKey();
  if(ck==='TODOS') return 1;
  const e = EXP_CLASE[emisor];
  if(!e||!e.TOTAL) return 0;
  return (e[ck]||0)/e.TOTAL;
}

// Formato
const fmtS = v => 'S/ ' + (v||0).toLocaleString('es-PE',{maximumFractionDigits:0});
const fmtP = v => v.toFixed(1)+'%';

// Normalizar nombre de departamento (coincide con Python _norm_dep)
function normDep(s){
  if(!s) return '';
  return s.trim().toUpperCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'');
}

// ---- Exposición efectiva de un distrito (filtra clase+sector) ----
function expEfectiva(d, sector){
  let tot=0;
  (d.ap||[]).forEach(a=>{
    if(sector!=='todos' && a.s!==sector) return;
    tot += a.m * classFrac(a.e);
  });
  return tot;
}

// ---- Poblar selectores de sector ----
const sectores = [...new Set(Object.values(EMP_SEC))].filter(Boolean).sort();
['selSectorMap','selSectorTbl'].forEach(id=>{
  const sel = document.getElementById(id);
  sectores.forEach(s=>{const o=document.createElement('option');o.value=s;o.textContent=s;sel.appendChild(o);});
});

// ================================================================
// MAPA FEN (Plotly choropleth a nivel DEPARTAMENTAL)
// ================================================================
function drawMapFen(){
  const colorear = document.getElementById('selColorear').value;
  const sector = document.getElementById('selSectorMap').value;
  const depFeats = GEO_DEP.features;

  // Para cada departamento: AUM de activos físicos
  const depAUM = {};
  D.forEach(d=>{
    const dep = d.dep;
    if(!dep) return;
    const e = expEfectiva(d, sector);
    if(e>0) depAUM[dep] = (depAUM[dep]||0) + e;
  });

  const locations=[], z=[], text=[], colorArr=[];
  depFeats.forEach(f=>{
    const dep = f.properties.NOMBDEP;
    const depN = normDep(dep);
    const cat = FEN_DEP[depN] || 'Sin datos';
    const catColor = (CAT_COL[cat]||{fill:'#ccc'}).fill;
    const aum = depAUM[dep] || 0;

    locations.push(dep);
    if(colorear==='fen'){
      // usar índice de categoría para colorscale
      z.push(CATS.indexOf(cat));
      colorArr.push(catColor);
    } else {
      z.push(aum);
    }
    const aumTxt = aum > 0 ? ('<br><b>AUM activos:</b> '+fmtS(aum)) : '<br><i>Sin activos en cartera</i>';
    text.push('<b>'+dep+'</b><br><b>Categoría FEN:</b> '+cat+aumTxt);
  });

  let colorscale, zmin, zmax;
  if(colorear==='fen'){
    // choropleth discreta: mapear índice de cat a color
    const n = CATS.length || 1;
    colorscale = CATS.map((c,i)=>{
      const col = (CAT_COL[c]||{fill:'#ccc'}).fill;
      return [[i/(n||1), col],[(i+1)/(n||1), col]];
    }).flat();
    zmin=0; zmax=n;
  } else {
    colorscale=[[0,'#eaf6f8'],[0.5,AFP.cyan],[1,AFP.azul]];
    zmin=0; zmax=undefined;
  }

  // GeoJSON departamental custom (featureidkey = NOMBDEP)
  const trace = {
    type:'choropleth',
    geojson: GEO_DEP,
    featureidkey:'properties.NOMBDEP',
    locations: locations,
    z: z,
    text: text,
    hoverinfo:'text',
    colorscale: colorscale,
    zmin: zmin, zmax: zmax,
    showscale: colorear!=='fen',
    marker:{line:{color:'#fff',width:1.2}},
    colorbar: colorear==='aum' ? {title:{text:'S/',side:'right'},thickness:12} : undefined,
  };

  const layout = {
    geo:{fitbounds:'locations',visible:false,bgcolor:'rgba(0,0,0,0)'},
    margin:{l:0,r:0,t:6,b:0},
    paper_bgcolor:'#fff',
  };

  Plotly.react('mapFen',[trace],layout,{displayModeBar:false,responsive:true});

  // Leyenda de categorías (siempre)
  const leg = document.getElementById('mapLegend');
  leg.innerHTML = CATS.map(c=>{
    const col = CAT_COL[c]||{fill:'#ccc',text:'#000'};
    return `<span class="sw"><i style="background:${col.fill}"></i>${c}</span>`;
  }).join('');
}

// ================================================================
// TABLA INTERACTIVA DE DOBLE ENTRADA
// ================================================================
function buildTablaFen(){
  const sector = document.getElementById('selSectorTbl').value;
  const ck = classKey();

  // Recalcular AUM por (cat FEN, nivel CENEPRED) filtrado por sector/clase
  const aum = {};       // cat -> nivel -> monto
  const aumCat = {};    // cat -> total

  D.forEach(d=>{
    const depN = normDep(d.dep);
    const cat = FEN_DEP[depN];
    if(!cat) return;
    const nivel = d.nivel;
    if(![1,2,3,4,5].includes(nivel)) return;
    let e=0;
    (d.ap||[]).forEach(a=>{
      if(sector!=='todos' && a.s!==sector) return;
      e += a.m * classFrac(a.e);
    });
    if(e<=0) return;
    if(!aum[cat]) aum[cat]={};
    aum[cat][nivel] = (aum[cat][nivel]||0)+e;
    aumCat[cat] = (aumCat[cat]||0)+e;
  });

  // Construir HTML
  const niveles = [5,4,3,2,1];
  const nColors = {5:'r5',4:'r4',3:'r3',2:'r2',1:'r1'};
  const showMonto = document.getElementById('chkMonto').checked;

  let h = '<thead><tr><th class="idx-h">Riesgo</th>';
  CATS.forEach(cat=>{
    const col = CAT_COL[cat]||{fill:'#ccc',text:'#000'};
    h += `<th style="background:${col.fill};color:${col.text}">${cat}</th>`;
  });
  h += '</tr></thead><tbody>';

  // filas por nivel
  niveles.forEach(lv=>{
    h += `<tr><td class="riesgo-cell ${nColors[lv]}">${lv}</td>`;
    CATS.forEach(cat=>{
      const v = (aum[cat]||{})[lv]||0;
      const den = aumCat[cat]||1;
      const pct = den>0 ? (v/den*100) : 0;
      const montoHtml = showMonto
        ? `<div class="sub-cell">${fmtS(v)}</div>` : '';
      h += `<td class="pct-cell">${fmtP(pct)}${montoHtml}</td>`;
    });
    h += '</tr>';
  });

  // Fila total (100% por definición)
  h += '<tr class="total-row"><td class="riesgo-cell">Σ</td>';
  CATS.forEach(cat=>{
    const den = aumCat[cat]||0;
    const montoHtml = showMonto ? `<div class="sub-cell">${fmtS(den)}</div>` : '';
    h += `<td class="pct-cell">100%${montoHtml}</td>`;
  });
  h += '</tr></tbody>';

  document.getElementById('tblFen').innerHTML = h;
}

// ================================================================
// SECCIÓN REGIONES FEN (tabla de regiones + tabla de empresas por región)
// ================================================================
// Etiqueta "Región - Categoría" de un departamento (normalizado)
function regionLabelOfDep(depN){
  const reg = REGION_DEP[depN];
  if(!reg) return null;
  const cat = FEN_DEP[depN];
  return cat ? (reg + ' - ' + cat) : reg;
}

// Conjunto fijo de etiquetas (no depende de la clase). Para poblar selectores.
const REGION_LABELS = (function(){
  const set = new Set();
  Object.keys(REGION_DEP).forEach(depN=>{ const l=regionLabelOfDep(depN); if(l) set.add(l); });
  return [...set].sort();
})();

// Agrupa por etiqueta: {label: {aum, emp:{emisor:{sector,n,aum}}}}.
// Solo activos físicos con nivel CENEPRED conocido (1-5). Respeta la clase (classFrac).
function buildRegionGroups(){
  const grupos = {};
  D.forEach(d=>{
    const label = regionLabelOfDep(normDep(d.dep));
    if(!label) return;
    if(![1,2,3,4,5].includes(d.nivel)) return;   // categoría CENEPRED conocida
    const g = grupos[label] || (grupos[label]={aum:0, emp:{}});
    (d.ap||[]).forEach(a=>{
      const m = a.m * classFrac(a.e);
      if(m<=0) return;
      const nAct = (a.ac && a.ac.length) ? a.ac.length : 1;
      g.aum += m;
      const e = g.emp[a.e] || (g.emp[a.e]={sector: EMP_SEC[a.e]||a.s||'', n:0, aum:0});
      e.n += nAct;
      e.aum += m;
    });
  });
  return grupos;
}

function getSelMulti(id){
  const sel = document.getElementById(id);
  return sel ? [...sel.selectedOptions].map(o=>o.value) : [];
}

let _gruposReg = null;   // cache válido para la clase actual

// ---- Tabla IZQUIERDA: Región | AUM Región | AUM Total | Peso(%) ----
function buildRegionIzq(){
  const g = _gruposReg || (_gruposReg = buildRegionGroups());
  const sel = getSelMulti('selRegIzq');
  const labels = sel.length ? sel : REGION_LABELS;   // si nada elegido, muestra todas
  const totalAll = REGION_LABELS.reduce((s,l)=> s + ((g[l]&&g[l].aum)||0), 0) || 1;
  let h = '<table class="regtbl"><thead><tr><th>Región</th><th>AUM Región</th>'+
          '<th>AUM Total</th><th>Peso (%)</th></tr></thead><tbody>';
  let any=false;
  labels.forEach(l=>{
    const aum = (g[l]&&g[l].aum)||0;
    if(aum<=0 && !sel.length) return;   // en modo "todas", omite vacías
    any=true;
    h += '<tr><td class="idx">'+l+'</td><td>'+fmtS(aum)+'</td>'+
         '<td>'+fmtS(totalAll)+'</td><td>'+fmtP(aum/totalAll*100)+'</td></tr>';
  });
  h += '</tbody></table>';
  document.getElementById('regTblIzq').innerHTML = any ? h
    : '<p class="reg-empty">Sin exposición para la selección.</p>';
}

// ---- Empresas combinadas a través de las regiones seleccionadas ----
function empresasDeRegiones(grupos, labels){
  const merged = {};
  labels.forEach(l=>{
    const g = grupos[l]; if(!g) return;
    Object.entries(g.emp).forEach(([emisor,info])=>{
      const e = merged[emisor] || (merged[emisor]={sector:info.sector, n:0, aum:0});
      e.n += info.n; e.aum += info.aum;
    });
  });
  return merged;
}

// ---- HTML de una tabla de empresas (con fila Total). titulo opcional (sector) ----
function tablaEmpresasHTML(empresas, titulo){
  const rows = Object.entries(empresas).sort((a,b)=> b[1].aum - a[1].aum);
  let totN=0, totA=0;
  let h = (titulo ? '<div class="reg-tbl-title">'+titulo+'</div>' : '') +
    '<table class="regtbl"><thead><tr><th>Empresa</th><th>Activos Físicos</th>'+
    '<th>AUM</th></tr></thead><tbody>';
  rows.forEach(([e,info])=>{
    totN += info.n; totA += info.aum;
    h += '<tr><td class="idx">'+e+'</td><td>'+info.n+'</td><td>'+fmtS(info.aum)+'</td></tr>';
  });
  h += '<tr class="reg-total"><td class="idx">Total</td><td>'+totN+'</td>'+
       '<td>'+fmtS(totA)+'</td></tr></tbody></table>';
  return h;
}

// ---- Tabla DERECHA: empresas por región (base o una por sector elegido) ----
function buildRegionDer(){
  const g = _gruposReg || (_gruposReg = buildRegionGroups());
  const selReg = getSelMulti('selRegDer');
  const labels = selReg.length ? selReg : REGION_LABELS;
  const selSec = getSelMulti('selSectorDer');
  const merged = empresasDeRegiones(g, labels);
  let html='';
  if(selSec.length === 0){
    // tabla base única
    html = Object.keys(merged).length
      ? tablaEmpresasHTML(merged, null)
      : '<p class="reg-empty">Sin empresas para la selección.</p>';
  } else {
    // una tabla por sector elegido (título = sector, alineado a la izquierda)
    selSec.forEach(sec=>{
      const sub={};
      Object.entries(merged).forEach(([e,info])=>{ if(info.sector===sec) sub[e]=info; });
      html += tablaEmpresasHTML(sub, sec);
    });
  }
  document.getElementById('regTblDer').innerHTML = html;
}

// Recalcula cache (por clase) y redibuja ambas tablas
function buildRegionSection(){
  _gruposReg = buildRegionGroups();
  buildRegionIzq();
  buildRegionDer();
}

// Poblar selectores de la sección (una sola vez)
(function initRegionSelectors(){
  ['selRegIzq','selRegDer'].forEach(id=>{
    const sel=document.getElementById(id);
    REGION_LABELS.forEach(l=>{
      const o=document.createElement('option'); o.value=l; o.textContent=l;
      o.selected=true;  // por defecto todas seleccionadas
      sel.appendChild(o);
    });
  });
  const selS=document.getElementById('selSectorDer');
  sectores.forEach(s=>{   // por defecto NINGUNO -> tabla base
    const o=document.createElement('option'); o.value=s; o.textContent=s;
    selS.appendChild(o);
  });
})();

// ================================================================
// RENDER
// ================================================================
function render(){
  drawMapFen();
  buildTablaFen();
  buildRegionSection();
}

// Tabs
document.querySelectorAll('.tab').forEach(b=>b.onclick=()=>{
  TAB = b.dataset.tab;
  document.querySelectorAll('.tab').forEach(x=>x.classList.toggle('active',x===b));
  render();
});

// Controles
['selColorear','selSectorMap'].forEach(id=>
  document.getElementById(id).addEventListener('change', drawMapFen));
document.getElementById('selSectorTbl').addEventListener('change', buildTablaFen);
document.getElementById('chkMonto').addEventListener('change', buildTablaFen);
// Selectores de la sección Regiones (independientes; no recalculan clase)
document.getElementById('selRegIzq').addEventListener('change', buildRegionIzq);
document.getElementById('selRegDer').addEventListener('change', buildRegionDer);
document.getElementById('selSectorDer').addEventListener('change', buildRegionDer);

document.getElementById('mTodos').onclick=()=>{
  SOLO_ACTIVOS=false;
  document.getElementById('mTodos').classList.add('on');
  document.getElementById('mActivo').classList.remove('on');
  render();
};
document.getElementById('mActivo').onclick=()=>{
  SOLO_ACTIVOS=true;
  document.getElementById('mActivo').classList.add('on');
  document.getElementById('mTodos').classList.remove('on');
  render();
};

render();
</script>
</body></html>
"""


# ==============================================================================
# HOOK EN MAIN() — llamada aditiva al final de main()
# ==============================================================================
def _generar_fen_chart(risk_path, out_dir, districts, exp_clase, aum_cartera,
                       emp_sector, geojson, scores, stamp):
    """Wrapper aditivo: carga FEN_Apoyo y genera los dos charts nuevos.
    Si algo falla, imprime warning y NO interrumpe el proceso principal."""
    try:
        fen_dep, categorias, region_dep = load_fen_apoyo(risk_path)
        if not fen_dep:
            return
        tabla_fen = build_fen_table_data(
            districts, fen_dep, categorias, exp_clase)
        # GeoJSON departamental embebido en activos_extension (DEP_GEOJSON_MIN)
        # Lo generamos aquí con el mismo dataset que ya tiene el script
        try:
            dep_geojson = DEP_GEOJSON_MIN   # definido en el módulo de activos
        except NameError:
            dep_geojson = {"type": "FeatureCollection", "features": []}
        html_out = os.path.join(out_dir, f"FEN_Impacto_{stamp}.html")
        export_html_fen(
            out_path=html_out,
            geojson_dep=dep_geojson,
            districts=districts,
            fen_dep=fen_dep,
            categorias=categorias,
            exp_clase=exp_clase,
            aum_cartera=aum_cartera,
            emp_sector=emp_sector,
            tabla_fen=tabla_fen,
            geojson_distrital=geojson,
            scores=scores,
            region_dep=region_dep,
        )
        log(f"[FEN_Apoyo] HTML FEN generado: {html_out}")
    except Exception as ex:
        import traceback
        log(f"[FEN_Apoyo] No se pudo generar el chart FEN (el resto no se afecta): "
            f"{ex}\n{traceback.format_exc()}", "WARN")





# Paleta corporativa (coincide con el padre; se sobre-escribe si llega vía AFP).
