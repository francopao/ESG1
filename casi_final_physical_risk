def log(msg, level="INFO"):
    print(f"[{level}] {msg}")


def fatal(msg):
    print("\n" + "=" * 78)
    print("ERROR — el proceso se detuvo. Revisa el detalle de abajo:")
    print("=" * 78)
    print(msg)
