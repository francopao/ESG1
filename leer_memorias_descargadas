def extraer_texto_pdf(ruta):
    """
    Devuelve (paginas, metricas):
      paginas  -> lista de dicts {num, texto, metodo}
      metricas -> dict con conteos por método y flag de procesabilidad.
    Pipeline por página: pdfplumber -> PyMuPDF -> OCR.
    """
    metricas = {"nativa": 0, "nativa_fitz": 0, "ocr": 0, "no_extraible": 0,
                "total": 0, "mayormente_no_procesable": False}
    paginas = []

    doc_fitz = None
    if PYMUPDF_DISPONIBLE:
        try:
            doc_fitz = fitz.open(ruta)
        except Exception as e:
            print(f"        [aviso] PyMuPDF no pudo abrir el PDF: {e}")
            doc_fitz = None

    with pdfplumber.open(ruta) as pdf:
        total = len(pdf.pages)
        metricas["total"] = total

        for i in range(total):
            num = i + 1
            texto = ""
            metodo = "no_extraible"

            # --- CAPA 1: pdfplumber ---
            try:
                texto = pdf.pages[i].extract_text() or ""
            except Exception:
                texto = ""
            if len(texto.strip()) >= UMBRAL_NATIVA:
                metodo = "nativa"

            # --- CAPA 2: PyMuPDF ---
            if metodo == "no_extraible" and doc_fitz is not None:
                try:
                    t2 = doc_fitz.load_page(i).get_text("text") or ""
                    if len(t2.strip()) >= UMBRAL_NATIVA:
                        texto, metodo = t2, "nativa_fitz"
                except Exception:
                    pass

            # --- CAPA 3: OCR ---
            if metodo == "no_extraible" and OCR_DISPONIBLE and doc_fitz is not None:
                try:
                    pagina = doc_fitz.load_page(i)
                    mat = fitz.Matrix(DPI_OCR / 72, DPI_OCR / 72)
                    pix = pagina.get_pixmap(matrix=mat, alpha=False)
                    img = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
                    t3 = pytesseract.image_to_string(img, lang="spa") or ""
                    if len(t3.strip()) >= UMBRAL_OCR:
                        texto, metodo = t3, "ocr"
                except Exception as e:
                    print(f"        [aviso] OCR falló en pág {num}: {e}")

            metricas[metodo] += 1
            paginas.append({"num": num, "texto": texto, "metodo": metodo})

    if doc_fitz is not None:
        doc_fitz.close()

    if metricas["total"] > 0:
        frac = metricas["no_extraible"] / metricas["total"]
        metricas["mayormente_no_procesable"] = frac > UMBRAL_NO_PROCESABLE

    return paginas, metricas


