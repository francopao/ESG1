_FONT_TITULO = Font(bold=True, size=13, color="FFFFFF")
_FILL_TITULO = PatternFill("solid", fgColor="1F4E78")
_FONT_SECCION = Font(bold=True, size=11, color="FFFFFF")
_FILL_SECCION = PatternFill("solid", fgColor="2E75B6")
_FONT_HEADER = Font(bold=True, size=10)
_FILL_HEADER = PatternFill("solid", fgColor="D9E1F2")
_FONT_LEYENDA = Font(italic=True, size=12, color="808080")
_BORDE = Border(*[Side(style="thin", color="BFBFBF")] * 4)


def _escribir_tabla(ws, fila, encabezados, filas_datos):
    for c, enc in enumerate(encabezados, start=1):
        cel = ws.cell(row=fila, column=c, value=enc)
        cel.font = _FONT_HEADER
        cel.fill = _FILL_HEADER
        cel.border = _BORDE
    fila += 1
    for datos in filas_datos:
        for c, val in enumerate(datos, start=1):
            cel = ws.cell(row=fila, column=c, value=val)
            cel.border = _BORDE
        fila += 1
    return fila + 1


def _titulo_seccion(ws, fila, texto, ancho=6):
    cel = ws.cell(row=fila, column=1, value=texto)
    cel.font = _FONT_SECCION
    for c in range(1, ancho + 1):
        ws.cell(row=fila, column=c).fill = _FILL_SECCION
    return fila + 1


def escribir_hoja_empresa(wb, empresa, archivos, datos, metricas_lista, estado):
    ws = wb.create_sheet(title=nombre_hoja_valido(empresa))

    cel = ws.cell(row=1, column=1, value=f"{empresa} — Estados Financieros")
    cel.font = _FONT_TITULO
    for c in range(1, 7):
        ws.cell(row=1, column=c).fill = _FILL_TITULO

    fila = 3
    ws.cell(row=fila, column=1, value="Archivo(s):").font = _FONT_HEADER
    ws.cell(row=fila, column=2, value=", ".join(os.path.basename(a) for a in archivos))
    fila += 1
    ws.cell(row=fila, column=1, value="Unidad de reporte:").font = _FONT_HEADER
    ws.cell(row=fila, column=2, value=(datos.get("unidad") or "—"))
    fila += 1
    ws.cell(row=fila, column=1, value="Estado de procesamiento:").font = _FONT_HEADER
    ws.cell(row=fila, column=2, value=estado)
    fila += 1

    agg = {"nativa": 0, "nativa_fitz": 0, "ocr": 0, "no_extraible": 0, "total": 0}
    for m in metricas_lista:
        for k in agg:
            agg[k] += m.get(k, 0)
    ws.cell(row=fila, column=1, value="Páginas (nat/fitz/ocr/no_ext/total):").font = _FONT_HEADER
    ws.cell(row=fila, column=2,
            value=f"{agg['nativa']} / {agg['nativa_fitz']} / {agg['ocr']} / "
                  f"{agg['no_extraible']} / {agg['total']}")
    fila += 2

    # Estados financieros (con líneas)
    fila = _titulo_seccion(ws, fila, "ESTADOS FINANCIEROS")
    filas = [[it.get("estado"), it.get("tipo"), it.get("concepto"),
              it.get("valor_2025"), it.get("valor_2024"), it.get("nota")]
             for it in (datos.get("consolidado") or [])]
    if not filas:
        filas = [["(sin estados con líneas; ver NOTAS / texto fuente)", "", "", "", "", ""]]
    fila = _escribir_tabla(ws, fila,
                           ["Estado", "Tipo", "Concepto", "2025", "2024", "Nota"], filas)

    # Desagregado por segmento / unidad de negocio
    fila = _titulo_seccion(ws, fila, "DESAGREGADO POR SEGMENTO / UNIDAD DE NEGOCIO (heurístico)")
    filas = [[it.get("unidad_negocio"), it.get("concepto"),
              it.get("valor_2025"), it.get("valor_2024"), it.get("unidad")]
             for it in (datos.get("desagregado") or [])]
    if not filas:
        filas = [["(sin desagregación detectada)", "", "", "", ""]]
    fila = _escribir_tabla(ws, fila,
                           ["Unidad de negocio", "Concepto", "2025", "2024", "Unidad"], filas)

    # Ratios / indicadores
    fila = _titulo_seccion(ws, fila, "RATIOS / INDICADORES")
    filas = [[it.get("nombre"), it.get("tipo"),
              it.get("valor_2025"), it.get("valor_2024")]
             for it in (datos.get("ratios") or [])]
    if not filas:
        filas = [["(sin ratios explícitos detectados)", "", "", ""]]
    fila = _escribir_tabla(ws, fila, ["Indicador", "Tipo", "2025", "2024"], filas)

    # Notas
    fila = _titulo_seccion(ws, fila, "NOTAS")
    nota_base = ("Cifras extraídas con parser local (heurístico). El bloque "
                 "'desagregado' proviene de prosa: verificar contra el documento "
                 "fuente. ")
    ws.cell(row=fila, column=1, value=nota_base + (datos.get("notas") or ""))
    ws.cell(row=fila, column=1).alignment = Alignment(wrap_text=True, vertical="top")

    for c, w in enumerate([34, 16, 46, 16, 16, 14], start=1):
        ws.column_dimensions[get_column_letter(c)].width = w


