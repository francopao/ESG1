# Token numérico: opcional paréntesis (negativo), miles con coma, decimal con punto
_VALOR = r"\(?-?\d[\d,]*(?:\.\d+)?\)?"

# Cola de "nota" al final del concepto (p.ej. "4.2.15 y 25", "33 (a)(v)")
NOTE_TAIL = re.compile(
    r"\s+\d+(?:\.\d+)*(?:\s*\([a-z0-9]+\))*(?:\s*y\s*\d+(?:\.\d+)*(?:\s*\([a-z0-9]+\))*)*\s*$",
    re.IGNORECASE)

# Cabecera de estado financiero (sobre texto sin acentos/min). Incluye nombres
# alternativos: "balance general", "ganancias y perdidas", patrimonio sin "neto".
HEADER_RE = re.compile(
    r"estado\s+(?P<tipo>separado|consolidado|individual)?\s*de\s+"
    r"(?P<estado>situacion financiera|balance general|resultados integrales|"
    r"ganancias y perdidas|resultados|cambios en el patrimonio neto|"
    r"cambios en el patrimonio|flujos de efectivo|flujo de efectivo)")
HEADER_AUDIT_RE = re.compile(r"estado\s+de\s+resultados\s+auditados")

# Terminadores: al verlos, se cierra el estado en curso
TERMINADORES = (
    "las notas adjuntas", "analisis de estados", "analisis y discusion",
    "seccion ", "anexo", "reporte sobre estructura accionaria",
    "datos generales", "carta del presidente",
)

# Palabras clave de ratios (restringidas: las genéricas como "cobertura" o
# "margen" generan falsos positivos en las tablas de notas de reportes grandes).
# Se usan límites de palabra para evitar subcadenas (p.ej. "roe" en "Electronoroeste").
RATIO_RE = re.compile(
    r"\b(?:ratio|roe|roa|ebitda|morosidad|apalancamiento|capital global)\b",
    re.IGNORECASE)

# Prosa: ROE/ROA por entidad   "ROE de Interbank ... 15.5% ... 12.2%"
ROE_ENT_RE = re.compile(
    r"\b(ROE|ROA)\s+de\s+([A-ZÁÉÍÓÚ][\wÁÉÍÓÚáéíóúñ&\.]+)"
    r"[^.%]{0,70}?(\d+(?:\.\d+)?)\s*%"
    r"(?:[^.%]{0,90}?(\d+(?:\.\d+)?)\s*%)?", re.IGNORECASE)

# Prosa: utilidad/resultado neto por entidad
UTIL_ENT_RE = re.compile(
    r"(?:utilidad|resultado)\s+(?:neta\s+|neto\s+)?de\s+"
    r"([A-ZÁÉÍÓÚ][\wÁÉÍÓÚáéíóúñ&\.]+)[^.]{0,50}?"
    r"(S/|US\$)\s*([\d.,]+)\s*millones", re.IGNORECASE)

# Prosa: EBITDA
EBITDA_RE = re.compile(r"EBITDA\s+de\s+(US\$|S/)\s*([\d.,]+)\s*millones", re.IGNORECASE)

_MAP_ESTADO = {
