    "balance general": "Situación financiera",
    "resultados integrales": "Resultados integrales",
    "resultados": "Resultados",
    "ganancias y perdidas": "Resultados",
    "cambios en el patrimonio neto": "Cambios en el patrimonio neto",
    "cambios en el patrimonio": "Cambios en el patrimonio neto",
    "flujos de efectivo": "Flujos de efectivo",
    "flujo de efectivo": "Flujos de efectivo",
}


def parse_num(token):
    """Convierte un token numérico a float/int (paréntesis=negativo, % y comas fuera)."""
    if token is None:
        return None
    t = token.strip()
    neg = t.startswith("(") and t.endswith(")")
    t = t.strip("()%").replace(",", "").replace(" ", "")
    if t in ("", "-", "."):
        return None
    try:
        v = float(t)
    except ValueError:
        return None
    if neg:
        v = -v
    return int(v) if v == int(v) else v


def _parsear_linea_item(linea):
    """
    Devuelve (concepto, nota, val_2025, val_2024) si la línea tiene dos columnas
    numéricas al final; de lo contrario None. Toma SIEMPRE las dos últimas cifras.
    """
    matches = list(re.finditer(_VALOR, linea))
    if len(matches) < 2:
        return None
    # Quitar "rulers" finales (líneas de subrayado tipo "____ ____") que algunas
    # memorias colocan tras las cifras en el estado de resultados.
    linea = re.sub(r"[\s_]+$", "", linea)
    matches = list(re.finditer(_VALOR, linea))
    if len(matches) < 2:
        return None
    m2 = matches[-1]   # 2024 (última)
    m1 = matches[-2]   # 2025 (penúltima)
    # Las dos cifras deben ser las últimas y estar contiguas (solo espacios entre sí)
    if linea[m2.end():].strip() != "":
        return None
    if linea[m1.end():m2.start()].strip() != "":
        return None
    concepto_raw = linea[:m1.start()].rstrip()
    v1 = parse_num(m1.group())
    v2 = parse_num(m2.group())
    if v1 is None or v2 is None:
        return None
    # Descartar cabeceras de año (p.ej. "Nota 2025 2024", "2025 2024")
    if v1 in ANIOS_VALIDOS and v2 in ANIOS_VALIDOS:
        return None
    # Separar nota al final del concepto
    nota = None
    mnota = NOTE_TAIL.search(concepto_raw)
    if mnota:
        candidato = concepto_raw[:mnota.start()].rstrip()
        if len(re.sub(r"[^a-zA-Z]", "", candidato)) >= 3:
            nota = concepto_raw[mnota.start():].strip()
            concepto_raw = candidato
    concepto = concepto_raw.strip(" .:-")
    if len(re.sub(r"[^a-zA-Z]", "", concepto)) < 3:
        return None
    return concepto, nota, v1, v2


def _es_terminador(norm):
    return any(norm.startswith(t) or t in norm[:40] for t in TERMINADORES)


def parsear_documento(paginas):
    """
    Parser principal. Recibe las páginas extraídas y devuelve un dict con:
      unidad, consolidado, desagregado, ratios, notas
    """
    datos = {"unidad": None, "consolidado": [], "desagregado": [],
             "ratios": [], "notas": ""}

    texto_completo = "\n".join(p["texto"] for p in paginas)
    lineas = texto_completo.splitlines()
    norm_full = sin_acentos_min(texto_completo)

    # --- Unidad de reporte ---
    if "us$(000)" in norm_full or "usd(000)" in norm_full:
        datos["unidad"] = "miles de dólares"
    elif "s/(000)" in norm_full:
        datos["unidad"] = "miles de soles"
    elif "millones de soles" in norm_full:
        datos["unidad"] = "millones de soles"
    elif "millones de dolares" in norm_full:
        datos["unidad"] = "millones de dólares"
    elif "us$" in norm_full and "millones" in norm_full and "s/" not in norm_full:
        datos["unidad"] = "millones de dólares (cifras en prosa)"
    elif "s/" in norm_full and "millones" in norm_full:
        datos["unidad"] = "millones de soles (cifras en prosa)"
    elif "us$" in norm_full and "millones" in norm_full:
        datos["unidad"] = "millones de dólares (cifras en prosa)"

    # --- Pase de líneas: estados con líneas + ámbito separado/consolidado ---
    estado_actual = None
    tipo_actual = None
    ambito = None
    lineas_en_estado = 0          # ventana de seguridad por estado abierto
    MAX_LINEAS_ESTADO = 90        # un estado real rara vez supera esto

    for linea in lineas:
        cruda = linea.rstrip()
        norm = sin_acentos_min(cruda).strip()
        if not norm:
            continue

        if "estados financieros separados" in norm:
            ambito = "separado"
        elif "estados financieros consolidados" in norm:
            ambito = "consolidado"

        # Cabecera de estado: SOLO si la línea es un título que EMPIEZA por
        # "estado" (evita falsos positivos cuando la frase aparece embebida en la
        # prosa de las notas, p.ej. "...reconocidos en el estado separado de...").
        # Se tolera numeración inicial ("1. Estado de...") y títulos largos que
        # incluyen la fecha o la unidad en la misma línea.
        norm_t = norm.lstrip("0123456789.()-•* \t")
        es_titulo = norm_t.startswith("estado") and len(norm_t) <= 140
        mh = HEADER_RE.match(norm_t) if es_titulo else None
        if mh:
            estado_actual = _MAP_ESTADO.get(mh.group("estado"))
            tipo_actual = mh.group("tipo") or ambito or "individual"
            lineas_en_estado = 0
            continue
        if es_titulo and HEADER_AUDIT_RE.match(norm_t):
            estado_actual = "Resultados"
            tipo_actual = ambito or "separado"
            lineas_en_estado = 0
            continue

        if _es_terminador(norm):
            estado_actual = None
            tipo_actual = None
            continue

        if estado_actual is not None:
            lineas_en_estado += 1
            if lineas_en_estado > MAX_LINEAS_ESTADO:
                estado_actual = None      # cierre por ventana (no es estado real)
                tipo_actual = None
                continue
            item = _parsear_linea_item(cruda)
            if item:
                concepto, nota, v1, v2 = item
                datos["consolidado"].append({
                    "estado": estado_actual, "tipo": tipo_actual,
                    "concepto": concepto, "valor_2025": v1,
                    "valor_2024": v2, "nota": nota})

    # --- Pase de ratios (tablas) ---
    ambito = None
    n = len(lineas)
    for i in range(n):
        cruda = lineas[i].rstrip()
        norm = sin_acentos_min(cruda).strip()
        if not norm:
            continue
        if "estados financieros separados" in norm:
            ambito = "separado"
        elif "estados financieros consolidados" in norm:
            ambito = "consolidado"
        if not RATIO_RE.search(cruda):
            continue
        item = _parsear_linea_item(cruda)
        if not item:
            # Nombre de ratio "envuelto": fusionar SOLO si esta línea no trae
            # cifras propias (evita pegar encabezados tipo "Ratios ... 2025 2024").
            if len(re.findall(_VALOR, cruda)) != 0:
                continue
            fusion = cruda
            intentos = 0
            j = i + 1
            while j < n and intentos < 2:
                sig = lineas[j].rstrip()
                if sig.strip():
                    fusion = fusion + " " + sig.strip()
                    item = _parsear_linea_item(fusion)
                    if item:
                        break
                    intentos += 1
                j += 1
            if not item:
                continue
        concepto, _nota, v1, v2 = item
        if v1 in ANIOS_VALIDOS and v2 in ANIOS_VALIDOS:
            continue  # cabecera "Ratios de Liquidez 2025 2024"
        # Un ratio/indicador no toma valores de miles ni cientos: descartar tablas
        # de notas (coberturas, derivados, métricas GRI) que cuelan números grandes.
        if abs(v1) > 100 or abs(v2) > 100:
            continue
        # Compactar espacios del nombre fusionado
        concepto = re.sub(r"\s+", " ", concepto).strip()
        datos["ratios"].append({
            "nombre": concepto, "tipo": ambito,
            "valor_2025": v1, "valor_2024": v2})

    # --- Pases de prosa (best effort) ---
    for m in ROE_ENT_RE.finditer(texto_completo):
        indicador, entidad = m.group(1).upper(), m.group(2).strip(" .")
        datos["desagregado"].append({
            "unidad_negocio": entidad, "concepto": indicador,
            "valor_2025": parse_num(m.group(3)),
            "valor_2024": parse_num(m.group(4)) if m.group(4) else None,
            "unidad": "%"})
    for m in UTIL_ENT_RE.finditer(texto_completo):
        entidad = m.group(1).strip(" .")
        moneda = "soles" if m.group(2) == "S/" else "dólares"
        datos["desagregado"].append({
            "unidad_negocio": entidad, "concepto": "Utilidad / resultado neto",
            "valor_2025": parse_num(m.group(3)), "valor_2024": None,
            "unidad": f"millones de {moneda}"})
    for m in EBITDA_RE.finditer(texto_completo):
        moneda = "soles" if m.group(1) == "S/" else "dólares"
        datos["ratios"].append({
            "nombre": f"EBITDA (millones de {moneda})", "tipo": None,
            "valor_2025": parse_num(m.group(2)), "valor_2024": None})

    datos["consolidado"] = _dedup(datos["consolidado"])
    datos["desagregado"] = _dedup(datos["desagregado"])
    datos["ratios"] = _dedup(datos["ratios"])
    return datos


def _dedup(filas):
    """Elimina dicts duplicados preservando el orden."""
    vistos = set()
    salida = []
    for f in filas:
        clave = tuple(sorted((k, str(v)) for k, v in f.items()))
        if clave not in vistos:
            vistos.add(clave)
            salida.append(f)
    return salida


