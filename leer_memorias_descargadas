def normalizar(texto):
    """Quita acentos, pasa a minúsculas y deja solo alfanuméricos."""
    texto = unicodedata.normalize("NFKD", texto)
    texto = "".join(c for c in texto if not unicodedata.combining(c))
    return re.sub(r"[^a-z0-9]", "", texto.lower())


def sin_acentos_min(texto):
    """Minúsculas sin acentos pero conservando espacios y signos (para regex)."""
    texto = unicodedata.normalize("NFKD", texto)
    texto = "".join(c for c in texto if not unicodedata.combining(c))
    return texto.lower()


def nombre_hoja_valido(nombre):
    """Sanea un nombre para hoja de Excel (<=31 chars, sin caracteres ilegales)."""
    nombre = re.sub(r"[\[\]\:\*\?\/\\]", " ", nombre).strip()
    return nombre[:31] if nombre else "Hoja"


def mapear_archivos_a_empresas():
    """
    Busca PDFs (recursivo y sin distinguir mayúsculas) y los empareja con una
    empresa canónica por coincidencia normalizada. Una empresa puede tener varios
    archivos (anexos '_1', '_2', '_6'); todos se procesan y se fusionan.
    Devuelve (mapeo, sin_emparejar, todos_los_pdfs).
    """
    todos = []
    if BUSQUEDA_RECURSIVA:
        for raiz, _dirs, files in os.walk(RUTA_BASE):
            if os.path.basename(raiz) == os.path.basename(RUTA_TEXTO_DUMP):
                continue  # no reprocesar nuestra propia carpeta de dumps
            for f in files:
                if f.lower().endswith(".pdf"):
                    todos.append(os.path.join(raiz, f))
    else:
        todos = [p for p in glob.glob(os.path.join(RUTA_BASE, "*"))
                 if p.lower().endswith(".pdf")]
    todos = sorted(set(todos))

    claves = sorted([(emp, normalizar(emp)) for emp in PORTAFOLIO],
                    key=lambda x: len(x[1]), reverse=True)
    # Añadir alias (nemónicos) como claves adicionales hacia su empresa canónica
    for emp, lista in ALIASES.items():
        for alias in lista:
            claves.append((emp, normalizar(alias)))
    claves.sort(key=lambda x: len(x[1]), reverse=True)

    mapeo = {}
    sin_emparejar = []
    for ruta in todos:
        base = os.path.basename(ruta)
        prefijo = re.split(r"_\d{4}|_MEMORIA|_\d", base, maxsplit=1)[0]
        clave_archivo = normalizar(prefijo) or normalizar(base)

        emparejado = None
        for emp, clave_emp in claves:
            if clave_emp and (clave_emp in clave_archivo or clave_archivo in clave_emp):
                emparejado = emp
                break
        if emparejado:
            mapeo.setdefault(emparejado, []).append(ruta)
        else:
            sin_emparejar.append(ruta)

    return mapeo, sin_emparejar, todos


