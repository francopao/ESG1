def main():
    print("=" * 70)
    print("EXTRACCIÓN DE ESTADOS FINANCIEROS — MEMORIAS SMV (AFP Integra)")
    print("Modo: 100% local (sin API)")
    print("=" * 70)
    print(f"Carpeta base : {RUTA_BASE}")
    print(f"PyMuPDF      : {PYMUPDF_DISPONIBLE}")
    print(f"OCR activo   : {OCR_DISPONIBLE}")
    print("-" * 70)

    if not os.path.isdir(RUTA_BASE):
        print("[ERROR] No existe la carpeta base. Verifica la ruta y reintenta.")
        return

    # 7.1 Mapear archivos a empresas + diagnóstico
    mapeo, sin_emparejar, todos = mapear_archivos_a_empresas()
    print(f"PDFs detectados en la carpeta (recursivo={BUSQUEDA_RECURSIVA}): {len(todos)}")
    if not todos:
        print("[DIAGNÓSTICO] No se encontró ningún .pdf. Contenido de la carpeta base:")
        try:
            for entrada in sorted(os.listdir(RUTA_BASE))[:40]:
                ruta_e = os.path.join(RUTA_BASE, entrada)
                tipo = "<DIR>" if os.path.isdir(ruta_e) else "     "
                print(f"   {tipo} {entrada}")
        except Exception as e:
            print(f"   (no se pudo listar la carpeta: {e})")
        print("   Sugerencias: revisa que los PDF estén en esta ruta (o subcarpetas),")
        print("   que la extensión sea .pdf y que OneDrive los tenga descargados localmente.")
    else:
        print(f"   Emparejados con el portafolio: "
              f"{sum(len(v) for v in mapeo.values())} en {len(mapeo)} empresa(s).")
        if sin_emparejar:
            print(f"   [aviso] {len(sin_emparejar)} sin emparejar: "
                  f"{[os.path.basename(a) for a in sin_emparejar]}")
    print("-" * 70)

    if GUARDAR_TEXTO_DUMP:
        try:
            os.makedirs(RUTA_TEXTO_DUMP, exist_ok=True)
        except Exception as e:
            print(f"[aviso] No se pudo crear carpeta de dumps: {e}")

    wb = Workbook()
    wb.remove(wb.active)
    filas_resumen = []

    # 7.2 Recorrer el portafolio EN ORDEN OFICIAL
    for idx, empresa in enumerate(PORTAFOLIO, start=1):
        print(f"[{idx:02d}/{len(PORTAFOLIO)}] {empresa}")

        if empresa not in mapeo:
            escribir_hoja_sin_documento(wb, empresa)
            if empresa in SIN_DOCUMENTO:
                estado = "Sin documento disponible en SMV"
                print("      -> Sin documento disponible en SMV.")
            else:
                estado = "Sin PDF en la carpeta"
                print("      -> No se encontró PDF en la carpeta.")
            filas_resumen.append([idx, empresa, estado, "—", "", "", "", ""])
            continue

        archivos = mapeo[empresa]
        paginas_totales = []
        metricas_lista = []
        notas_proceso = []

        for ruta in archivos:
            base = os.path.basename(ruta)
            try:
                print(f"      Extrayendo texto de: {base}")
                paginas, metricas = extraer_texto_pdf(ruta)
                paginas_totales.extend(paginas)
                metricas_lista.append(metricas)
                etiqueta = (" [MAYORMENTE NO PROCESABLE]"
                            if metricas["mayormente_no_procesable"] else "")
                print(f"        páginas: nat={metricas['nativa']} "
                      f"fitz={metricas['nativa_fitz']} ocr={metricas['ocr']} "
                      f"no_ext={metricas['no_extraible']} "
                      f"total={metricas['total']}{etiqueta}")
                if metricas["mayormente_no_procesable"]:
                    notas_proceso.append(f"{base}: mayormente no procesable")
            except Exception as e:
                print(f"        [ERROR] No se pudo procesar {base}: {e}")
                notas_proceso.append(f"{base}: ERROR de extracción ({e})")
                metricas_lista.append({"nativa": 0, "nativa_fitz": 0, "ocr": 0,
                                       "no_extraible": 0, "total": 0,
                                       "mayormente_no_procesable": True})

        # Volcado de texto para auditoría
        if GUARDAR_TEXTO_DUMP and paginas_totales:
            try:
                destino = os.path.join(RUTA_TEXTO_DUMP, f"{nombre_hoja_valido(empresa)}.txt")
                with open(destino, "w", encoding="utf-8") as fh:
                    for p in paginas_totales:
                        fh.write(f"\n===== Página {p['num']} [{p['metodo']}] =====\n")
                        fh.write(p["texto"] or "")
            except Exception as e:
                print(f"      [aviso] No se pudo guardar el dump de texto: {e}")

        # Parseo local
        try:
            datos = parsear_documento(paginas_totales)
        except Exception as e:
            print(f"      [ERROR] Falló el parseo local: {e}")
            datos = {"unidad": None, "consolidado": [], "desagregado": [],
                     "ratios": [], "notas": f"Parseo fallido: {e}"}

        if notas_proceso:
            datos["notas"] = (datos.get("notas", "") + " || " +
                              " || ".join(notas_proceso)).strip(" |")

        agg = {"nativa": 0, "nativa_fitz": 0, "ocr": 0, "no_extraible": 0, "total": 0}
        for m in metricas_lista:
            for k in agg:
                agg[k] += m.get(k, 0)
        hay_eeff = bool(datos.get("consolidado") or datos.get("ratios"))
        if agg["total"] == 0:
            estado = "PDF no legible / error"
        elif any(m.get("mayormente_no_procesable") for m in metricas_lista):
            estado = "Procesado parcialmente (mayormente no procesable)"
        elif hay_eeff:
            estado = "Procesado OK"
        else:
            estado = "Procesado (sin EEFF: posible anexo, p.ej. reporte 10190)"

        escribir_hoja_empresa(wb, empresa, archivos, datos, metricas_lista, estado)
        filas_resumen.append([
            idx, empresa, estado,
            ", ".join(os.path.basename(a) for a in archivos),
            agg["nativa"], agg["nativa_fitz"], agg["ocr"], agg["no_extraible"]])
        print(f"      -> {estado} "
              f"(EEFF:{len(datos['consolidado'])} ratios:{len(datos['ratios'])} "
              f"desagr:{len(datos['desagregado'])})")

    # 7.3 Resumen y guardado
    escribir_hoja_resumen(wb, filas_resumen)
    try:
        wb.save(RUTA_SALIDA_EXCEL)
        print("-" * 70)
        print(f"[OK] Excel generado en:\n     {RUTA_SALIDA_EXCEL}")
    except PermissionError:
        alterno = RUTA_SALIDA_EXCEL.replace(
            ".xlsx", f"_{time.strftime('%Y%m%d_%H%M%S')}.xlsx")
        wb.save(alterno)
        print(f"[OK] El destino estaba bloqueado; guardado en:\n     {alterno}")
    except Exception as e:
        print(f"[ERROR] No se pudo guardar el Excel: {e}")

    print("=" * 70)
    print("Proceso finalizado.")
    print("=" * 70)


if __name__ == "__main__":
    main()
